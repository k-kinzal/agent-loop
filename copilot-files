#!/usr/bin/env bash
#
# copilot-files - Run GitHub Copilot CLI once per file from a file list
#
# USAGE
#     copilot-files [OPTIONS] [--] [COPILOT_ARGS...]
#
# DESCRIPTION
#     Reads newline-delimited file paths from one or more file lists and
#     launches GitHub Copilot CLI once per line. Copilot runs under a managed
#     agentStop hook so the wrapper regains control after each completed turn
#     and starts the next file in a fresh session.
#
#     Relative paths in the file list are resolved from the current working
#     directory.
#
# OPTIONS
#     --files-from PATH
#         Read newline-delimited file paths from PATH. Repeatable.
#         Use `-` to read from stdin. When omitted, stdin is used if available.
#
#     --include PATTERN
#         Glob pattern to include (repeatable)
#         When omitted, all listed files are included
#
#     --exclude PATTERN
#         Glob pattern to exclude (repeatable)
#
#     --ignore PATTERN
#         Alias for --exclude
#
#     --max-files N
#         Stop after N matching files. Default: 0 (all)
#
#     --completion-promise TEXT
#         Stop after a Copilot run whose final response contains TEXT
#
#     --debug
#         Enable debug logging for both copilot-files and copilot
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to copilot. If no explicit copilot
#     mode or subcommand is provided, a single positional prompt is treated as
#     `copilot -i "<prompt>"`.
#
# TEMPLATE VARIABLES
#     {{file}}    Replaced with the current file path
#     {{files}}   Replaced with the current file path for compatibility with
#                 `*-watch` prompts
#
# EXAMPLES
#     copilot-files --files-from files.txt -- -p "review {{file}}"
#     printf '%s\n' src/a.ts src/b.ts | copilot-files -- -p "fix {{file}}"
#     copilot-files --files-from files.txt --max-files 10 -- -p "analyze {{file}}"
#
# DEPENDENCIES
#     - copilot (GitHub Copilot CLI)
#     - jq (JSON processor)
#

set -euo pipefail

readonly GITHUB_DIR="${PWD}/.github"
readonly HOOKS_DIR="${GITHUB_DIR}/hooks"
readonly STATE_FILE="${GITHUB_DIR}/copilot-files.state.json"
readonly HOOK_SCRIPT_PATH="${HOOKS_DIR}/copilot-files-hook.sh"
readonly HOOK_CONFIG_PATH="${HOOKS_DIR}/copilot-files.json"
readonly HOOK_SCRIPT_BACKUP="${HOOK_SCRIPT_PATH}.copilot-files-backup"
readonly HOOK_CONFIG_BACKUP="${HOOK_CONFIG_PATH}.copilot-files-backup"
readonly HOOK_LOG_FILE="${GITHUB_DIR}/copilot-files-hook.log"

FILES_FROM=()
INCLUDE_PATTERNS=()
IGNORE_PATTERNS=()
MAX_FILES=0
COMPLETION_PROMISE=""
COPILOT_ARGS=()
INPUT_FILES=()
DEBUG=false
PROCESSED_COUNT=0

log() { [[ "$DEBUG" == "true" ]] && echo "[copilot-files] $1" >&2 || true; }
log_error() { echo "[copilot-files] ERROR: $1" >&2; }

copilot_option_takes_value() {
  case "$1" in
    --add-dir|--add-github-mcp-tool|--add-github-mcp-toolset|--additional-mcp-config|--agent|--config-dir|--disable-mcp-server|--effort|--interactive|--log-dir|--log-level|--max-autopilot-continues|--model|--output-format|--plugin-dir|--prompt|--reasoning-effort|--stream)
      return 0
      ;;
    --allow-tool|--allow-url|--alt-screen|--available-tools|--bash-env|--deny-tool|--deny-url|--excluded-tools|--mouse|--resume|--secret-env-vars|--share)
      return 0
      ;;
  esac
  return 1
}

copilot_has_explicit_mode_or_command() {
  local i arg
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    arg="${COPILOT_ARGS[$i]}"
    case "$arg" in
      -p|--prompt|-i|--interactive|--continue|--resume|--resume=*|--acp|--help|-h|-v|--version)
        return 0
        ;;
    esac
    if copilot_option_takes_value "$arg"; then
      ((i++))
      continue
    fi
    if [[ "$arg" != -* ]]; then
      case "$arg" in
        help|init|login|plugin|update|version)
          return 0
          ;;
      esac
      break
    fi
  done
  return 1
}

find_implicit_prompt_index() {
  local i arg prompt_index=""
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    arg="${COPILOT_ARGS[$i]}"
    case "$arg" in
      -p|--prompt|-i|--interactive|--continue|--resume|--resume=*|--acp|--help|-h|-v|--version)
        return 1
        ;;
    esac
    if copilot_option_takes_value "$arg"; then
      ((i++))
      continue
    fi
    if [[ "$arg" != -* ]]; then
      case "$arg" in
        help|init|login|plugin|update|version)
          return 1
          ;;
      esac
      if [[ -n "$prompt_index" ]]; then
        return 1
      fi
      prompt_index="$i"
    fi
  done
  [[ -n "$prompt_index" ]] || return 1
  printf '%s\n' "$prompt_index"
}

prepare_copilot_args() {
  local arg i prompt_index prompt_value
  local has_log_level=false
  local prepared_args=()

  if [[ "$DEBUG" == "true" ]]; then
    for arg in "${COPILOT_ARGS[@]}"; do
      case "$arg" in
        --log-level|--log-level=*)
          has_log_level=true
          break
          ;;
      esac
    done
    if [[ "$has_log_level" != "true" ]]; then
      COPILOT_ARGS=(--log-level debug "${COPILOT_ARGS[@]}")
    fi
  fi

  if copilot_has_explicit_mode_or_command; then
    return
  fi

  prompt_index=$(find_implicit_prompt_index || true)
  [[ -n "$prompt_index" ]] || return

  prompt_value="${COPILOT_ARGS[$prompt_index]}"
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    if [[ "$i" -eq "$prompt_index" ]]; then
      prepared_args+=(-i "$prompt_value")
    else
      prepared_args+=("${COPILOT_ARGS[$i]}")
    fi
  done
  COPILOT_ARGS=("${prepared_args[@]}")
  log "inferred interactive prompt mode from positional prompt"
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) { exit }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

check_dependencies() {
  command -v jq >/dev/null 2>&1 || { log_error "jq is required but not installed."; exit 1; }
  command -v copilot >/dev/null 2>&1 || { log_error "copilot CLI is required but not installed."; exit 1; }
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --files-from)
        [[ $# -ge 2 ]] || { log_error "--files-from requires a value."; exit 1; }
        FILES_FROM+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --include)
        [[ $# -ge 2 ]] || { log_error "--include requires a value."; exit 1; }
        INCLUDE_PATTERNS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --exclude|--ignore)
        [[ $# -ge 2 ]] || { log_error "$1 requires a value."; exit 1; }
        IGNORE_PATTERNS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --max-files)
        [[ $# -ge 2 ]] || { log_error "--max-files requires a value."; exit 1; }
        MAX_FILES="$2"; shift 2 ;;
      --completion-promise)
        [[ $# -ge 2 ]] || { log_error "--completion-promise requires a value."; exit 1; }
        COMPLETION_PROMISE="$2"; shift 2 ;;
      --debug)
        DEBUG=true; shift ;;
      --help|-h)
        show_usage; exit 0 ;;
      --)
        shift; COPILOT_ARGS+=("$@"); break ;;
      *)
        COPILOT_ARGS+=("$1"); shift ;;
    esac
  done
}

backup_hook_files() {
  rm -f "$HOOK_SCRIPT_BACKUP" "$HOOK_CONFIG_BACKUP"
  if [[ -f "$HOOK_SCRIPT_PATH" ]]; then
    cp "$HOOK_SCRIPT_PATH" "$HOOK_SCRIPT_BACKUP"
  fi
  if [[ -f "$HOOK_CONFIG_PATH" ]]; then
    cp "$HOOK_CONFIG_PATH" "$HOOK_CONFIG_BACKUP"
  fi
}

restore_hook_file() {
  local path="$1"
  local backup="$2"
  if [[ -f "$backup" ]]; then
    mv "$backup" "$path"
  else
    rm -f "$path"
  fi
}

expand_leading_tilde() {
  local value="$1"
  case "$value" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s\n' "$HOME/${value#"~/"}" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

path_to_absolute() {
  local path="$1"
  path=$(expand_leading_tilde "$path")
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    .) printf '%s\n' "$PWD" ;;
    ./*) printf '%s\n' "$PWD/${path#./}" ;;
    *) printf '%s\n' "$PWD/$path" ;;
  esac
}

path_relative_to_pwd() {
  local path="$1"
  local abs_pwd="${PWD%/}"
  local abs_path
  abs_path=$(path_to_absolute "$path")
  if [[ "$abs_path" == "$abs_pwd" ]]; then
    printf '.\n'
  elif [[ "$abs_path" == "$abs_pwd/"* ]]; then
    printf '%s\n' "${abs_path#"$abs_pwd"/}"
  else
    printf '%s\n' "$path"
  fi
}

value_matches_glob_pattern() {
  local prefix="$1"
  local value="$2"
  local remaining="$3"

  if [[ "$remaining" == *'**/'* ]]; then
    local before="${remaining%%'**/'*}"
    local after="${remaining#*'**/'}"
    value_matches_glob_pattern "${prefix}${before}**/" "$value" "$after" && return 0
    value_matches_glob_pattern "${prefix}${before}" "$value" "$after" && return 0
    return 1
  fi

  [[ "$value" == ${prefix}${remaining} ]]
}

path_matches_pattern() {
  local path="$1"
  local pattern="$2"
  local abs_path rel_path basename
  abs_path=$(path_to_absolute "$path")
  rel_path=$(path_relative_to_pwd "$path")
  basename=$(basename -- "$path")
  value_matches_glob_pattern "" "$path" "$pattern" \
    || value_matches_glob_pattern "" "$abs_path" "$pattern" \
    || value_matches_glob_pattern "" "$rel_path" "$pattern" \
    || value_matches_glob_pattern "" "$basename" "$pattern"
}

should_skip_path() {
  local path="$1"
  [[ "$(basename -- "$path")" == ".DS_Store" ]]
}

should_track_path() {
  local path="$1"
  local pattern

  should_skip_path "$path" && return 1

  if [[ ${#INCLUDE_PATTERNS[@]} -gt 0 ]]; then
    local matched=false
    for pattern in "${INCLUDE_PATTERNS[@]}"; do
      if path_matches_pattern "$path" "$pattern"; then
        matched=true
        break
      fi
    done
    [[ "$matched" == "true" ]] || return 1
  fi

  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    if path_matches_pattern "$path" "$pattern"; then
      return 1
    fi
  done

  return 0
}

process_file_list() {
  local source="$1"
  local line path

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    [[ -n "$line" ]] || continue
    path=$(expand_leading_tilde "$line")
    if [[ ! -f "$path" ]]; then
      log "skipping missing or non-regular file from $source: $line"
      continue
    fi
    if ! should_track_path "$path"; then
      log "skipping filtered file from $source: $path"
      continue
    fi
    INPUT_FILES+=("$path")
  done
}

collect_input_files() {
  local source

  if [[ ${#FILES_FROM[@]} -eq 0 ]]; then
    if [[ -t 0 ]]; then
      log_error "no file list provided. Use --files-from PATH or pipe newline-delimited paths on stdin."
      exit 1
    fi
    FILES_FROM=("-")
  fi

  for source in "${FILES_FROM[@]}"; do
    if [[ "$source" == "-" ]]; then
      log "reading file list from stdin"
      process_file_list "stdin"
    else
      [[ -f "$source" ]] || { log_error "file list does not exist: $source"; exit 1; }
      log "reading file list from $source"
      process_file_list "$source" < "$source"
    fi
  done

  [[ ${#INPUT_FILES[@]} -gt 0 ]] || { log_error "no matching files found in the provided file list."; exit 1; }
}

validate_config() {
  [[ "$MAX_FILES" =~ ^[0-9]+$ ]] || { log_error "max-files must be a non-negative integer."; exit 1; }
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  mkdir -p "$GITHUB_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [ "$decision" = "null" ]; then echo "null"; else echo "\"$decision\""; fi),
  "hook_called": $hook_called
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  backup_hook_files
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${PWD}/.github/copilot-files.state.json"
DEBUG_FLAG_FILE="${PWD}/.github/copilot-files.debug"
HOOK_LOG_FILE="${PWD}/.github/copilot-files-hook.log"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

extract_last_assistant_message() {
  local transcript_path="$1"
  [[ -n "$transcript_path" && -f "$transcript_path" ]] || return 0
  jq -r '
    select(.type == "assistant.message")
    | .data.content // empty
  ' "$transcript_path" 2>/dev/null | tail -n 1 || true
}

INPUT=$(cat)

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcriptPath // empty')
COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
ASSISTANT_TEXT=$(extract_last_assistant_message "$TRANSCRIPT_PATH")

debug_log "agentStop hook started: completion_promise=${COMPLETION_PROMISE:-<none>} transcript_path=${TRANSCRIPT_PATH:-<none>}"

DECISION="done"
if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  DECISION="complete"
  debug_log "decision=complete (completion promise matched)"
else
  debug_log "decision=done"
fi

jq --arg d "$DECISION" '.decision = $d | .hook_called = true' \
  "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

PARENT_PID=$(ps -o ppid= "$$" 2>/dev/null | tr -d ' ')
GRANDPARENT_PID=""
if [[ -n "$PARENT_PID" ]]; then
  GRANDPARENT_PID=$(ps -o ppid= "$PARENT_PID" 2>/dev/null | tr -d ' ' || true)
fi

debug_log "sending SIGTERM to parent/copilot processes parent=${PARENT_PID:-<none>} grandparent=${GRANDPARENT_PID:-<none>}"
[[ -n "$PARENT_PID" ]] && kill -TERM "$PARENT_PID" 2>/dev/null || true
[[ -n "$GRANDPARENT_PID" ]] && kill -TERM "$GRANDPARENT_PID" 2>/dev/null || true

exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  cat > "$HOOK_CONFIG_PATH" << 'EOF'
{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": "./.github/hooks/copilot-files-hook.sh"
      }
    ]
  }
}
EOF

  if [[ "$DEBUG" == "true" ]]; then
    touch "${GITHUB_DIR}/copilot-files.debug"
  fi
}

cleanup() {
  local exit_code=$?
  trap - EXIT INT TERM
  restore_hook_file "$HOOK_SCRIPT_PATH" "$HOOK_SCRIPT_BACKUP"
  restore_hook_file "$HOOK_CONFIG_PATH" "$HOOK_CONFIG_BACKUP"
  rm -f "${GITHUB_DIR}/copilot-files.debug"
  rm -f "$HOOK_LOG_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  rm -f "$STATE_FILE"
  rmdir "$GITHUB_DIR" 2>/dev/null || true
  exit "$exit_code"
}

expand_template() {
  local current_file="$1"
  EXPANDED_ARGS=()
  for arg in "${COPILOT_ARGS[@]}"; do
    arg="${arg//\{\{files\}\}/$current_file}"
    arg="${arg//\{\{file\}\}/$current_file}"
    EXPANDED_ARGS+=("$arg")
  done
}

run_copilot_once() {
  local -a args=("$@")

  write_state "null" "false"

  set +e
  copilot "${args[@]}"
  local copilot_exit_code=$?
  set -e

  local decision hook_called
  decision=$(read_decision)
  hook_called=$(read_hook_called)

  log "copilot exited (code=$copilot_exit_code, decision=$decision, hook=$hook_called)"

  LAST_EXIT_CODE=$copilot_exit_code
  LAST_DECISION=$decision
  LAST_HOOK_CALLED=$hook_called
}

eval_run_result() {
  if [[ "$LAST_HOOK_CALLED" != "true" ]]; then
    case "$LAST_EXIT_CODE" in
      129|130|137|143)
        if [[ "$LAST_DECISION" != "done" && "$LAST_DECISION" != "complete" ]]; then
          log "interrupted by signal while processing $CURRENT_FILE"
          WRAPPER_EXIT_CODE=$LAST_EXIT_CODE
          return 1
        fi
        ;;
    esac
    log "hook not called; exiting with copilot's status"
    WRAPPER_EXIT_CODE=$LAST_EXIT_CODE
    return 1
  fi

  case "$LAST_DECISION" in
    complete)
      log "completion promise matched after file $PROCESSED_COUNT"
      WRAPPER_EXIT_CODE=0
      return 1
      ;;
    done)
      return 0
      ;;
    *)
      log_error "unexpected decision: $LAST_DECISION"
      WRAPPER_EXIT_CODE=1
      return 1
      ;;
  esac
}

main() {
  parse_args "$@"
  validate_config
  check_dependencies
  prepare_copilot_args
  collect_input_files

  if [[ ${#COPILOT_ARGS[@]} -eq 0 ]]; then
    log_error "no arguments provided for copilot. See --help for usage."
    exit 1
  fi

  trap cleanup EXIT INT TERM

  log "files=${#INPUT_FILES[@]} include_patterns=${INCLUDE_PATTERNS[*]:-<none>} exclude_patterns=${IGNORE_PATTERNS[*]:-<none>} max_files=$MAX_FILES completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script

  WRAPPER_EXIT_CODE=0

  for CURRENT_FILE in "${INPUT_FILES[@]}"; do
    if [[ "$MAX_FILES" -gt 0 ]] && [[ "$PROCESSED_COUNT" -ge "$MAX_FILES" ]]; then
      log "maximum files reached: $MAX_FILES"
      break
    fi

    PROCESSED_COUNT=$((PROCESSED_COUNT + 1))
    log "processing file $PROCESSED_COUNT/${#INPUT_FILES[@]}: $CURRENT_FILE"
    expand_template "$CURRENT_FILE"
    run_copilot_once "${EXPANDED_ARGS[@]}"
    if ! eval_run_result; then
      return "$WRAPPER_EXIT_CODE"
    fi
  done
}

main "$@"
