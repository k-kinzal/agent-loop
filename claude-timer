#!/usr/bin/env bash
#
# claude-timer - Run Claude Code on a cron schedule
#
# USAGE
#     claude-timer [OPTIONS] [--] [CLAUDE_ARGS...]
#
# DESCRIPTION
#     Waits for the next minute that matches a 5-field cron expression, then
#     launches Claude Code. After Claude finishes its turn, the wrapper waits
#     for the next matching minute and launches Claude again in a fresh
#     session.
#
#     Schedule resolution is one minute, matching standard cron behavior.
#     The timer checks at minute boundaries and does not backfill triggers
#     missed while Claude was already running.
#
# OPTIONS
#     --cron EXPR
#         Cron expression in "minute hour day month weekday" format.
#         Supports ranges, lists, steps, month names, weekday names, and
#         aliases such as @hourly, @daily, @weekly, @monthly, and @yearly.
#
#     --max-triggers N
#         Stop after N scheduled Claude runs. Default: 0 (unlimited)
#
#     --completion-promise TEXT
#         Stop after a Claude run whose final response contains TEXT
#
#     --debug
#         Enable debug logging (both claude-timer and claude)
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to claude.
#
# EXAMPLES
#     claude-timer --cron '0 * * * *' -- -p "summarize repo status"
#     claude-timer --cron '*/15 9-18 * * 1-5' -- "review open work"
#     claude-timer --cron '@daily' --completion-promise "DONE" -- "work"
#
# DEPENDENCIES
#     - claude (Claude Code CLI)
#     - jq (JSON processor)
#

set -euo pipefail

readonly CLAUDE_DIR="${PWD}/.claude"
readonly HOOKS_DIR="${CLAUDE_DIR}/hooks"
readonly STATE_FILE="${CLAUDE_DIR}/claude-timer.state.json"
readonly SETTINGS_LOCAL="${CLAUDE_DIR}/settings.local.json"
readonly SETTINGS_PROJECT="${CLAUDE_DIR}/settings.json"
readonly HOOK_SCRIPT_PATH="${HOOKS_DIR}/claude-timer-hook.sh"
readonly HOOK_LOG_FILE="${CLAUDE_DIR}/claude-timer-hook.log"
readonly EXISTING_HOOKS_FILE="${CLAUDE_DIR}/claude-timer-existing-hooks.json"

CRON_EXPR=""
MAX_TRIGGERS=0
COMPLETION_PROMISE=""
CLAUDE_ARGS=()
SETTINGS_MODIFIED=false
TARGET_SETTINGS_FILE=""
TARGET_SETTINGS_BACKUP=""
DEBUG=false
TRIGGER_COUNT=0
DATE_BACKEND=""

MINUTE_FIELD=""
HOUR_FIELD=""
DAY_OF_MONTH_FIELD=""
MONTH_FIELD=""
DAY_OF_WEEK_FIELD=""

MINUTE_VALUES=""
HOUR_VALUES=""
DAY_OF_MONTH_VALUES=""
MONTH_VALUES=""
DAY_OF_WEEK_VALUES=""

LAST_EXIT_CODE=0
LAST_DECISION="null"
LAST_HOOK_CALLED="false"
TIMER_EXIT_CODE=0

log() { [[ "$DEBUG" == "true" ]] && echo "[claude-timer] $1" >&2 || true; }
log_error() { echo "[claude-timer] ERROR: $1" >&2; }

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) {
        exit
      }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

check_dependencies() {
  command -v jq >/dev/null 2>&1 || { log_error "jq is required but not installed."; exit 1; }
  command -v claude >/dev/null 2>&1 || { log_error "claude CLI is required but not installed."; exit 1; }
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cron)
        [[ $# -ge 2 ]] || { log_error "--cron requires a value."; exit 1; }
        CRON_EXPR="$2"; shift 2 ;;
      --max-triggers)
        [[ $# -ge 2 ]] || { log_error "--max-triggers requires a value."; exit 1; }
        MAX_TRIGGERS="$2"; shift 2 ;;
      --completion-promise)
        [[ $# -ge 2 ]] || { log_error "--completion-promise requires a value."; exit 1; }
        COMPLETION_PROMISE="$2"; shift 2 ;;
      --debug)
        DEBUG=true; CLAUDE_ARGS+=("$1"); shift ;;
      --help|-h)
        show_usage; exit 0 ;;
      --)
        shift; CLAUDE_ARGS+=("$@"); break ;;
      *)
        CLAUDE_ARGS+=("$1"); shift ;;
    esac
  done
}

init_date_backend() {
  if date -r 0 '+%Y' >/dev/null 2>&1; then
    DATE_BACKEND="bsd"
  elif date -d '@0' '+%Y' >/dev/null 2>&1; then
    DATE_BACKEND="gnu"
  else
    log_error "this system date command is not supported."
    exit 1
  fi
}

format_epoch() {
  local epoch="$1"
  local format="$2"
  case "$DATE_BACKEND" in
    bsd) date -r "$epoch" "$format" ;;
    gnu) date -d "@$epoch" "$format" ;;
    *)
      log_error "date backend not initialized."
      exit 1
      ;;
  esac
}

epoch_to_cron_fields() {
  format_epoch "$1" '+%M %H %d %m %w'
}

format_human_time() {
  format_epoch "$1" '+%Y-%m-%d %H:%M:%S %Z'
}

normalize_cron_expr() {
  case "$CRON_EXPR" in
    @yearly|@annually) CRON_EXPR='0 0 1 1 *' ;;
    @monthly)          CRON_EXPR='0 0 1 * *' ;;
    @weekly)           CRON_EXPR='0 0 * * 0' ;;
    @daily|@midnight)  CRON_EXPR='0 0 * * *' ;;
    @hourly)           CRON_EXPR='0 * * * *' ;;
  esac
}

normalize_field_names() {
  local value="$1"
  local kind="$2"

  value=$(printf '%s' "$value" | tr '[:lower:]' '[:upper:]')
  case "$kind" in
    month)
      value="${value//JAN/1}"
      value="${value//FEB/2}"
      value="${value//MAR/3}"
      value="${value//APR/4}"
      value="${value//MAY/5}"
      value="${value//JUN/6}"
      value="${value//JUL/7}"
      value="${value//AUG/8}"
      value="${value//SEP/9}"
      value="${value//OCT/10}"
      value="${value//NOV/11}"
      value="${value//DEC/12}"
      ;;
    weekday)
      value="${value//SUN/0}"
      value="${value//MON/1}"
      value="${value//TUE/2}"
      value="${value//WED/3}"
      value="${value//THU/4}"
      value="${value//FRI/5}"
      value="${value//SAT/6}"
      ;;
  esac

  printf '%s\n' "$value"
}

parse_cron_number() {
  local raw="$1"
  local min="$2"
  local max="$3"
  local field_name="$4"

  [[ "$raw" =~ ^[0-9]+$ ]] || {
    log_error "invalid $field_name field value: $raw"
    exit 1
  }

  local value=$((10#$raw))
  (( value >= min && value <= max )) || {
    log_error "$field_name field value out of range: $raw"
    exit 1
  }

  printf '%s\n' "$value"
}

canonicalize_weekday() {
  local value="$1"
  if [[ "$value" -eq 7 ]]; then
    printf '0\n'
  else
    printf '%s\n' "$value"
  fi
}

build_value_set() {
  local raw_field="$1"
  local parse_min="$2"
  local parse_max="$3"
  local output_min="$4"
  local output_max="$5"
  local kind="$6"
  local field_name="$7"
  local output_var="$8"
  local normalized part base step start end current canonical values=""
  local -a allowed=()

  normalized=$(normalize_field_names "$raw_field" "$kind")
  IFS=',' read -r -a parts <<< "$normalized"

  [[ ${#parts[@]} -gt 0 ]] || {
    log_error "invalid $field_name field: $raw_field"
    exit 1
  }

  for part in "${parts[@]}"; do
    [[ -n "$part" ]] || {
      log_error "invalid $field_name field: $raw_field"
      exit 1
    }

    base="$part"
    step=1
    if [[ "$part" == */* ]]; then
      [[ "$part" != */*/* ]] || {
        log_error "invalid $field_name field step: $part"
        exit 1
      }
      base="${part%/*}"
      step="${part#*/}"
      [[ "$step" =~ ^[0-9]+$ ]] || {
        log_error "invalid $field_name field step: $part"
        exit 1
      }
      (( 10#$step > 0 )) || {
        log_error "$field_name field step must be greater than zero: $part"
        exit 1
      }
      step=$((10#$step))
    fi

    if [[ "$base" == "*" ]]; then
      start="$parse_min"
      end="$parse_max"
    elif [[ "$base" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      start=$(parse_cron_number "${BASH_REMATCH[1]}" "$parse_min" "$parse_max" "$field_name")
      end=$(parse_cron_number "${BASH_REMATCH[2]}" "$parse_min" "$parse_max" "$field_name")
      (( start <= end )) || {
        log_error "$field_name field range start exceeds end: $part"
        exit 1
      }
    else
      start=$(parse_cron_number "$base" "$parse_min" "$parse_max" "$field_name")
      end="$start"
    fi

    for ((current=start; current<=end; current+=step)); do
      if [[ "$kind" == "weekday" ]]; then
        canonical=$(canonicalize_weekday "$current")
      else
        canonical="$current"
      fi
      allowed[$canonical]=1
    done
  done

  for ((current=output_min; current<=output_max; current++)); do
    [[ "${allowed[$current]:-0}" == "1" ]] || continue
    if [[ -n "$values" ]]; then
      values+=" "
    fi
    values+="$current"
  done

  [[ -n "$values" ]] || {
    log_error "invalid $field_name field: $raw_field"
    exit 1
  }

  printf -v "$output_var" '%s' "$values"
}

value_in_set() {
  local values="$1"
  local needle="$2"
  [[ " $values " == *" $needle "* ]]
}

cron_matches_epoch() {
  local epoch="$1"
  local minute hour day_of_month month day_of_week
  local dom_match=false
  local dow_match=false

  read -r minute hour day_of_month month day_of_week <<< "$(epoch_to_cron_fields "$epoch")"
  minute=$((10#$minute))
  hour=$((10#$hour))
  day_of_month=$((10#$day_of_month))
  month=$((10#$month))
  day_of_week=$((10#$day_of_week))

  value_in_set "$MINUTE_VALUES" "$minute" || return 1
  value_in_set "$HOUR_VALUES" "$hour" || return 1
  value_in_set "$MONTH_VALUES" "$month" || return 1

  value_in_set "$DAY_OF_MONTH_VALUES" "$day_of_month" && dom_match=true
  value_in_set "$DAY_OF_WEEK_VALUES" "$day_of_week" && dow_match=true

  if [[ "$DAY_OF_MONTH_FIELD" == "*" && "$DAY_OF_WEEK_FIELD" == "*" ]]; then
    return 0
  fi
  if [[ "$DAY_OF_MONTH_FIELD" == "*" ]]; then
    [[ "$dow_match" == "true" ]]
    return
  fi
  if [[ "$DAY_OF_WEEK_FIELD" == "*" ]]; then
    [[ "$dom_match" == "true" ]]
    return
  fi

  [[ "$dom_match" == "true" || "$dow_match" == "true" ]]
}

validate_config() {
  [[ -n "$CRON_EXPR" ]] || { log_error "--cron is required."; exit 1; }
  [[ "$MAX_TRIGGERS" =~ ^[0-9]+$ ]] || { log_error "max-triggers must be a non-negative integer."; exit 1; }

  normalize_cron_expr
  init_date_backend

  local -a fields=()
  read -r -a fields <<< "$CRON_EXPR"
  [[ ${#fields[@]} -eq 5 ]] || {
    log_error "cron expression must contain exactly 5 fields."
    exit 1
  }

  MINUTE_FIELD="${fields[0]}"
  HOUR_FIELD="${fields[1]}"
  DAY_OF_MONTH_FIELD="${fields[2]}"
  MONTH_FIELD="${fields[3]}"
  DAY_OF_WEEK_FIELD="${fields[4]}"

  build_value_set "$MINUTE_FIELD" 0 59 0 59 minute minute MINUTE_VALUES
  build_value_set "$HOUR_FIELD" 0 23 0 23 hour hour HOUR_VALUES
  build_value_set "$DAY_OF_MONTH_FIELD" 1 31 1 31 day_of_month day-of-month DAY_OF_MONTH_VALUES
  build_value_set "$MONTH_FIELD" 1 12 1 12 month month MONTH_VALUES
  build_value_set "$DAY_OF_WEEK_FIELD" 0 7 0 6 weekday day-of-week DAY_OF_WEEK_VALUES
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  mkdir -p "$CLAUDE_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [ "$decision" = "null" ]; then echo "null"; else echo "\"$decision\""; fi),
  "hook_called": $hook_called
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-timer.state.json"
DEBUG_FLAG_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-timer.debug"
HOOK_LOG_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-timer-hook.log"
EXISTING_HOOKS_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-timer-existing-hooks.json"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

INPUT=$(cat)

if [[ -f "$EXISTING_HOOKS_FILE" ]] && [[ "$(jq 'length' "$EXISTING_HOOKS_FILE")" -gt 0 ]]; then
  HOOK_COUNT=$(jq 'length' "$EXISTING_HOOKS_FILE")
  debug_log "Running $HOOK_COUNT existing hook(s) before claude-timer logic"
  for ((i=0; i<HOOK_COUNT; i++)); do
    HOOK_CMD=$(jq -r ".[$i]" "$EXISTING_HOOKS_FILE")
    debug_log "Running existing hook $((i+1))/$HOOK_COUNT: $HOOK_CMD"
    RESULT=""
    RESULT=$(printf '%s' "$INPUT" | eval "$HOOK_CMD" 2>/dev/null) || true
    if [[ -n "$RESULT" ]]; then
      HOOK_CONTINUE=$(printf '%s' "$RESULT" | jq -r '.continue // "null"' 2>/dev/null) || HOOK_CONTINUE="null"
      if [[ "$HOOK_CONTINUE" != "false" ]]; then
        debug_log "Existing hook $((i+1)) blocked stop (continue=$HOOK_CONTINUE), forwarding with continue=true"
        printf '%s' "$RESULT" | jq -c '. + {"continue": true}'
        exit 0
      fi
    fi
    debug_log "Existing hook $((i+1)) passed"
  done
  debug_log "All $HOOK_COUNT existing hook(s) passed, proceeding with claude-timer logic"
fi

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
LAST_ASSISTANT_MESSAGE=$(echo "$INPUT" | jq -r '.last_assistant_message // empty')
TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')
ASSISTANT_TEXT="$LAST_ASSISTANT_MESSAGE"

debug_log "Stop hook started: completion_promise=${COMPLETION_PROMISE:-<none>} transcript_path=${TRANSCRIPT_PATH:-<none>}"

if [[ -z "$ASSISTANT_TEXT" ]] && [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
  ASSISTANT_TEXT=$(jq -r '
    select(.type == "assistant")
    | .message.content[]?
    | select(.type == "text")
    | .text // empty
  ' "$TRANSCRIPT_PATH" 2>/dev/null | tail -n 1 || true)
fi

DECISION="done"
if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  DECISION="complete"
  debug_log "decision=complete (completion promise matched)"
else
  debug_log "decision=done"
fi

jq --arg d "$DECISION" '.decision = $d | .hook_called = true' \
  "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

CLAUDE_PID=$(ps -o ppid= $$ 2>/dev/null | tr -d ' ')
if [[ -n "$CLAUDE_PID" ]]; then
  debug_log "sending SIGTERM to claude process (PID=$CLAUDE_PID)"
  kill -TERM "$CLAUDE_PID" 2>/dev/null || true
fi
exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  if [[ "$DEBUG" == "true" ]]; then
    touch "${CLAUDE_DIR}/claude-timer.debug"
  fi
}

extract_existing_stop_hooks() {
  local hooks_json="[]"
  if [[ -f "$TARGET_SETTINGS_FILE" ]] && jq -e '.hooks.Stop' "$TARGET_SETTINGS_FILE" >/dev/null 2>&1; then
    hooks_json=$(jq '[.hooks.Stop[]?.hooks[]? | select(.type == "command") | .command]' "$TARGET_SETTINGS_FILE")
  fi
  echo "$hooks_json" > "$EXISTING_HOOKS_FILE"
  log "extracted existing stop hooks: $(cat "$EXISTING_HOOKS_FILE")"
}

merge_settings() {
  mkdir -p "$CLAUDE_DIR"

  local hook_entry='{"hooks":[{"type":"command","command":"\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/claude-timer-hook.sh"}]}'

  if [[ -f "$SETTINGS_PROJECT" ]] && jq -e '.hooks.Stop' "$SETTINGS_PROJECT" >/dev/null 2>&1; then
    TARGET_SETTINGS_FILE="$SETTINGS_PROJECT"
  else
    TARGET_SETTINGS_FILE="$SETTINGS_LOCAL"
  fi
  TARGET_SETTINGS_BACKUP="${TARGET_SETTINGS_FILE}.claude-timer-backup"

  if [[ -f "$TARGET_SETTINGS_FILE" ]]; then
    cp "$TARGET_SETTINGS_FILE" "$TARGET_SETTINGS_BACKUP"
  fi

  extract_existing_stop_hooks

  if [[ -f "$TARGET_SETTINGS_FILE" ]]; then
    local existing
    existing=$(cat "$TARGET_SETTINGS_FILE")
    if echo "$existing" | jq -e '.hooks' >/dev/null 2>&1; then
      echo "$existing" | jq --argjson hook "$hook_entry" '.hooks.Stop = [$hook]' > "$TARGET_SETTINGS_FILE"
    else
      echo "$existing" | jq --argjson hook "$hook_entry" '.hooks = {"Stop": [$hook]}' > "$TARGET_SETTINGS_FILE"
    fi
  else
    cat > "$TARGET_SETTINGS_FILE" << 'EOF'
{"hooks":{"Stop":[{"hooks":[{"type":"command","command":"\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/claude-timer-hook.sh"}]}]}}
EOF
  fi

  SETTINGS_MODIFIED=true
  log "hook registered in $(basename "$TARGET_SETTINGS_FILE")"
}

restore_settings() {
  if [[ "$SETTINGS_MODIFIED" == "true" ]] && [[ -n "$TARGET_SETTINGS_FILE" ]]; then
    if [[ -f "$TARGET_SETTINGS_BACKUP" ]]; then
      mv "$TARGET_SETTINGS_BACKUP" "$TARGET_SETTINGS_FILE"
    else
      rm -f "$TARGET_SETTINGS_FILE"
    fi
    SETTINGS_MODIFIED=false
  fi
}

cleanup() {
  local exit_code=$?
  rm -f "$HOOK_SCRIPT_PATH"
  rm -f "${CLAUDE_DIR}/claude-timer.debug"
  rm -f "$EXISTING_HOOKS_FILE"
  rm -f "$HOOK_LOG_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  restore_settings
  rm -f "$STATE_FILE"
  exit "$exit_code"
}

run_claude_once() {
  local -a args=("$@")
  log "claude args (${#args[@]}): $(printf "'%s' " "${args[@]}")"

  write_state "null" "false"

  set +e
  claude "${args[@]}"
  local claude_exit_code=$?
  set -e

  local decision hook_called
  decision=$(read_decision)
  hook_called=$(read_hook_called)

  log "claude exited (code=$claude_exit_code, decision=$decision, hook=$hook_called)"

  LAST_EXIT_CODE=$claude_exit_code
  LAST_DECISION=$decision
  LAST_HOOK_CALLED=$hook_called
}

eval_run_result() {
  if [[ "$LAST_HOOK_CALLED" != "true" ]]; then
    case "$LAST_EXIT_CODE" in
      129|130|137|143)
        log "interrupted by signal"
        TIMER_EXIT_CODE=$LAST_EXIT_CODE
        return 1
        ;;
    esac
    log "hook not called; exiting with claude's status"
    TIMER_EXIT_CODE=$LAST_EXIT_CODE
    return 1
  fi

  case "$LAST_DECISION" in
    complete)
      log "completion promise matched after trigger $TRIGGER_COUNT"
      TIMER_EXIT_CODE=0
      return 1
      ;;
    done)
      return 0
      ;;
    *)
      log_error "unexpected decision: $LAST_DECISION"
      TIMER_EXIT_CODE=1
      return 1
      ;;
  esac
}

next_minute_boundary_epoch() {
  local now
  now=$(date +%s)
  printf '%s\n' $(( ((now / 60) + 1) * 60 ))
}

current_minute_epoch() {
  local now
  now=$(date +%s)
  printf '%s\n' $(( (now / 60) * 60 ))
}

sleep_until_epoch() {
  local target="$1"
  while true; do
    local now remaining
    now=$(date +%s)
    remaining=$((target - now))
    (( remaining <= 0 )) && return 0
    sleep "$remaining"
  done
}

main() {
  for arg in "$@"; do
    [[ "$arg" == "--help" || "$arg" == "-h" ]] && { show_usage; exit 0; }
  done

  check_dependencies
  parse_args "$@"
  validate_config

  if [[ ${#CLAUDE_ARGS[@]} -eq 0 ]]; then
    log_error "no arguments provided for claude. See --help for usage."
    exit 1
  fi

  trap cleanup EXIT INT TERM

  log "cron=$CRON_EXPR max_triggers=$MAX_TRIGGERS completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script
  merge_settings

  TIMER_EXIT_CODE=0

  while true; do
    local target_epoch check_epoch
    target_epoch=$(next_minute_boundary_epoch)
    log "next schedule check at $(format_human_time "$target_epoch")"
    sleep_until_epoch "$target_epoch"

    check_epoch=$(current_minute_epoch)
    if ! cron_matches_epoch "$check_epoch"; then
      log "schedule did not match at $(format_human_time "$check_epoch")"
      continue
    fi

    TRIGGER_COUNT=$((TRIGGER_COUNT + 1))
    log "schedule matched at $(format_human_time "$check_epoch"), running claude (trigger $TRIGGER_COUNT)"

    run_claude_once "${CLAUDE_ARGS[@]}"
    if ! eval_run_result; then
      return "$TIMER_EXIT_CODE"
    fi

    if [[ "$MAX_TRIGGERS" -gt 0 ]] && [[ "$TRIGGER_COUNT" -ge "$MAX_TRIGGERS" ]]; then
      log "maximum triggers reached: $TRIGGER_COUNT"
      return 0
    fi

    log "trigger $TRIGGER_COUNT complete, waiting for next schedule"
  done
}

main "$@"
