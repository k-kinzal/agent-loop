#!/usr/bin/env bash
#
# claude-loop - Run Claude Code in a managed Stop-hook loop
#
# USAGE
#     claude-loop [OPTIONS] [--] [CLAUDE_ARGS...]
#
# DESCRIPTION
#     Runs Claude Code under a managed Stop hook until a termination condition
#     is met. The hook keeps Claude working by blocking Stop events until the
#     completion promise or max-iteration condition is satisfied.
#
# OPTIONS
#     --max-iteration N
#         Stop after N iterations. Default: 0 (unlimited)
#
#     --completion-promise TEXT
#         Stop when TEXT appears in Claude's output
#
#     --debug
#         Enable debug logging (both claude-loop and claude)
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to claude.
#
# EXAMPLES
#     claude-loop --max-iteration 5 "implement feature X"
#     claude-loop --completion-promise "DONE" "work until done"
#     claude-loop --max-iteration 3 -p "say hello"
#     claude-loop --max-iteration 3 --model sonnet "hello"
#
# DEPENDENCIES
#     - claude (Claude Code CLI)
#     - jq (JSON processor)
#

set -euo pipefail

readonly CLAUDE_DIR="${PWD}/.claude"
readonly HOOKS_DIR="${CLAUDE_DIR}/hooks"
readonly STATE_FILE="${CLAUDE_DIR}/claude-loop.state.json"
readonly SETTINGS_LOCAL="${CLAUDE_DIR}/settings.local.json"
readonly SETTINGS_PROJECT="${CLAUDE_DIR}/settings.json"
readonly HOOK_SCRIPT_PATH="${HOOKS_DIR}/claude-loop-hook.sh"
readonly HOOK_LOG_FILE="${CLAUDE_DIR}/claude-loop-hook.log"
readonly EXISTING_HOOKS_FILE="${CLAUDE_DIR}/claude-loop-existing-hooks.json"

ITERATION=1
MAX_ITERATIONS=0
COMPLETION_PROMISE=""
CLAUDE_ARGS=()
SETTINGS_MODIFIED=false
TARGET_SETTINGS_FILE=""
TARGET_SETTINGS_BACKUP=""
DEBUG=false

log() { [[ "$DEBUG" == "true" ]] && echo "[claude-loop] $1" >&2 || true; }
log_error() { echo "[claude-loop] ERROR: $1" >&2; }

check_dependencies() {
  command -v jq &>/dev/null || { log_error "jq is required but not installed."; exit 1; }
  command -v claude &>/dev/null || { log_error "claude CLI is required but not installed."; exit 1; }
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-iteration)      MAX_ITERATIONS="$2"; shift 2 ;;
      --completion-promise) COMPLETION_PROMISE="$2"; shift 2 ;;
      --debug)              DEBUG=true; CLAUDE_ARGS+=("$1"); shift ;;
      --)                   shift; CLAUDE_ARGS+=("$@"); break ;;
      *)                    CLAUDE_ARGS+=("$1"); shift ;;
    esac
  done
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  local stop_reason="${3:-}"
  mkdir -p "$CLAUDE_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "iteration": $ITERATION,
  "max_iterations": $MAX_ITERATIONS,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [ "$decision" = "null" ]; then echo "null"; else echo "\"$decision\""; fi),
  "hook_called": $hook_called,
  "stop_reason": $(printf '%s' "$stop_reason" | jq -Rs .)
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_iteration() {
  [[ -f "$STATE_FILE" ]] && jq -r '.iteration // 1' "$STATE_FILE" || echo "1"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

read_stop_reason() {
  [[ -f "$STATE_FILE" ]] && jq -r '.stop_reason // ""' "$STATE_FILE" || echo ""
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-loop.state.json"
DEBUG_FLAG_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-loop.debug"
HOOK_LOG_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-loop-hook.log"
EXISTING_HOOKS_FILE="${CLAUDE_PROJECT_DIR}/.claude/claude-loop-existing-hooks.json"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

INPUT=$(cat)

# Run existing hooks first; if any blocks stop, defer to it
if [[ -f "$EXISTING_HOOKS_FILE" ]] && [[ "$(jq 'length' "$EXISTING_HOOKS_FILE")" -gt 0 ]]; then
  HOOK_COUNT=$(jq 'length' "$EXISTING_HOOKS_FILE")
  debug_log "Running $HOOK_COUNT existing hook(s) before agent-loop logic"
  for ((i=0; i<HOOK_COUNT; i++)); do
    HOOK_CMD=$(jq -r ".[$i]" "$EXISTING_HOOKS_FILE")
    debug_log "Running existing hook $((i+1))/$HOOK_COUNT: $HOOK_CMD"
    RESULT=""
    RESULT=$(printf '%s' "$INPUT" | eval "$HOOK_CMD" 2>/dev/null) || true
    if [[ -n "$RESULT" ]]; then
      HOOK_CONTINUE=$(printf '%s' "$RESULT" | jq -r '.continue // "null"' 2>/dev/null) || HOOK_CONTINUE="null"
      if [[ "$HOOK_CONTINUE" != "false" ]]; then
        debug_log "Existing hook $((i+1)) blocked stop (continue=$HOOK_CONTINUE), forwarding with continue=true"
        printf '%s' "$RESULT" | jq -c '. + {"continue": true}'
        exit 0
      fi
    fi
    debug_log "Existing hook $((i+1)) passed"
  done
  debug_log "All $HOOK_COUNT existing hook(s) passed, proceeding with agent-loop logic"
fi

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')
ITERATION=$(echo "$STATE" | jq -r '.iteration // 1')
MAX_ITERATIONS=$(echo "$STATE" | jq -r '.max_iterations // 0')
COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
LAST_ASSISTANT_MESSAGE=$(echo "$INPUT" | jq -r '.last_assistant_message // empty')
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false')
ASSISTANT_TEXT="$LAST_ASSISTANT_MESSAGE"

debug_log "Stop hook started: iteration=$ITERATION max_iterations=$MAX_ITERATIONS stop_hook_active=$STOP_HOOK_ACTIVE transcript_path=${TRANSCRIPT_PATH:-<none>}"

if [[ -z "$ASSISTANT_TEXT" ]] && [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
  ASSISTANT_TEXT=$(jq -r '
    select(.type == "assistant")
    | .message.content[]?
    | select(.type == "text")
    | .text // empty
  ' "$TRANSCRIPT_PATH" 2>/dev/null | tail -n 1 || true)
fi

if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  debug_log "decision=complete iteration=$ITERATION"
  jq '.decision = "complete" | .hook_called = true | .stop_reason = "Completion promise matched."' \
    "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  jq -cn --arg reason "Completion promise matched." '{"continue": false, "stopReason": $reason}'
  exit 0
fi

if [[ "$MAX_ITERATIONS" -gt 0 ]] && [[ "$ITERATION" -ge "$MAX_ITERATIONS" ]]; then
  debug_log "decision=max_reached iteration=$ITERATION/$MAX_ITERATIONS"
  jq '.decision = "max_reached" | .hook_called = true | .stop_reason = "Maximum iterations reached."' \
    "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  jq -cn --arg reason "Maximum iterations reached." '{"continue": false, "stopReason": $reason}'
  exit 0
fi

NEW_ITERATION=$((ITERATION + 1))
debug_log "decision=continue iteration=$ITERATION->$NEW_ITERATION"
jq --argjson iter "$NEW_ITERATION" '.iteration = $iter | .decision = "continue" | .hook_called = true | .stop_reason = ""' \
  "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

# Terminate Claude process so the wrapper can restart it
CLAUDE_PID=$(ps -o ppid= $$ 2>/dev/null | tr -d ' ')
if [[ -n "$CLAUDE_PID" ]]; then
  debug_log "sending SIGTERM to claude process (PID=$CLAUDE_PID)"
  kill -TERM "$CLAUDE_PID" 2>/dev/null || true
fi
exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  if [[ "$DEBUG" == "true" ]]; then
    touch "${CLAUDE_DIR}/claude-loop.debug"
  fi
}

extract_existing_stop_hooks() {
  local hooks_json="[]"
  if [[ -f "$TARGET_SETTINGS_FILE" ]] && jq -e '.hooks.Stop' "$TARGET_SETTINGS_FILE" &>/dev/null; then
    hooks_json=$(jq '[.hooks.Stop[]?.hooks[]? | select(.type == "command") | .command]' "$TARGET_SETTINGS_FILE")
  fi
  echo "$hooks_json" > "$EXISTING_HOOKS_FILE"
  log "extracted existing stop hooks: $(cat "$EXISTING_HOOKS_FILE")"
}

merge_settings() {
  mkdir -p "$CLAUDE_DIR"

  local hook_entry='{"hooks":[{"type":"command","command":"\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/claude-loop-hook.sh"}]}'

  # Determine target: use the file where existing Stop hooks are defined.
  # hooks arrays are replaced (not merged) across settings scopes,
  # so we must add our hook to the same file as existing hooks.
  if [[ -f "$SETTINGS_PROJECT" ]] && jq -e '.hooks.Stop' "$SETTINGS_PROJECT" &>/dev/null; then
    TARGET_SETTINGS_FILE="$SETTINGS_PROJECT"
  else
    TARGET_SETTINGS_FILE="$SETTINGS_LOCAL"
  fi
  TARGET_SETTINGS_BACKUP="${TARGET_SETTINGS_FILE}.claude-loop-backup"

  # Backup
  if [[ -f "$TARGET_SETTINGS_FILE" ]]; then
    cp "$TARGET_SETTINGS_FILE" "$TARGET_SETTINGS_BACKUP"
  fi

  # Extract existing Stop hook commands before modifying settings
  extract_existing_stop_hooks

  # Replace Stop hooks with only our wrapper hook (which runs existing hooks internally)
  if [[ -f "$TARGET_SETTINGS_FILE" ]]; then
    local existing
    existing=$(cat "$TARGET_SETTINGS_FILE")

    if echo "$existing" | jq -e '.hooks' &>/dev/null; then
      echo "$existing" | jq --argjson hook "$hook_entry" '.hooks.Stop = [$hook]' > "$TARGET_SETTINGS_FILE"
    else
      echo "$existing" | jq --argjson hook "$hook_entry" '.hooks = {"Stop": [$hook]}' > "$TARGET_SETTINGS_FILE"
    fi
  else
    cat > "$TARGET_SETTINGS_FILE" << 'EOF'
{"hooks":{"Stop":[{"hooks":[{"type":"command","command":"\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/claude-loop-hook.sh"}]}]}}
EOF
  fi

  SETTINGS_MODIFIED=true
  log "hook registered in $(basename "$TARGET_SETTINGS_FILE")"
}

restore_settings() {
  if [[ "$SETTINGS_MODIFIED" == "true" ]] && [[ -n "$TARGET_SETTINGS_FILE" ]]; then
    if [[ -f "$TARGET_SETTINGS_BACKUP" ]]; then
      mv "$TARGET_SETTINGS_BACKUP" "$TARGET_SETTINGS_FILE"
    else
      rm -f "$TARGET_SETTINGS_FILE"
    fi
    SETTINGS_MODIFIED=false
  fi
}

cleanup() {
  local exit_code=$?
  rm -f "$HOOK_SCRIPT_PATH"
  rm -f "${CLAUDE_DIR}/claude-loop.debug"
  rm -f "$EXISTING_HOOKS_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  restore_settings
  rm -f "$STATE_FILE"
  exit $exit_code
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) {
        exit
      }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

main() {
  for arg in "$@"; do
    [[ "$arg" == "--help" || "$arg" == "-h" ]] && { show_usage; exit 0; }
  done

  check_dependencies
  parse_args "$@"

  if [[ ${#CLAUDE_ARGS[@]} -eq 0 ]]; then
    log_error "no arguments provided for claude. See --help for usage."
    exit 1
  fi

  trap cleanup EXIT INT TERM

  log "max_iterations=$MAX_ITERATIONS completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script
  merge_settings

  while true; do
    write_state "null" "false"
    log "starting claude (iteration $ITERATION)"

    set +e
    claude "${CLAUDE_ARGS[@]}"
    local claude_exit_code=$?
    set -e

    local decision hook_called stop_reason
    decision=$(read_decision)
    hook_called=$(read_hook_called)
    ITERATION=$(read_iteration)
    stop_reason=$(read_stop_reason)

    log "claude exited (code=$claude_exit_code, decision=$decision, hook=$hook_called, reason=${stop_reason:-<none>})"

    # Signal exit codes are only interruptions if the hook didn't
    # intentionally cause them (SIGTERM is sent by the hook to restart)
    if [[ "$decision" != "continue" ]]; then
      case $claude_exit_code in
        129|130|137|143)
          log "interrupted by signal"
          return "$claude_exit_code"
          ;;
      esac
    fi

    if [[ "$hook_called" != "true" ]]; then
      log "hook not called; exiting with claude's status"
      return "$claude_exit_code"
    fi

    case "$decision" in
      complete|max_reached)
        log "finished after $ITERATION iteration(s): ${stop_reason:-<none>}"
        return 0
        ;;
      continue)
        log "iteration $((ITERATION - 1)) complete, restarting claude"
        ;;
      *)
        log_error "unexpected decision: $decision"
        return 1
        ;;
    esac
  done
}

main "$@"
