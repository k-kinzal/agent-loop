#!/usr/bin/env bash
#
# copilot-loop - Run GitHub Copilot CLI in a managed agentStop-hook loop
#
# USAGE
#     copilot-loop [OPTIONS] [--] [COPILOT_ARGS...]
#
# DESCRIPTION
#     Runs GitHub Copilot CLI under a managed agentStop hook until a
#     termination condition is met. The hook records the final assistant
#     message from Copilot's session transcript, decides whether the loop
#     should continue, and terminates the current Copilot process so the
#     wrapper can start a fresh session.
#
# OPTIONS
#     --max-iteration N
#         Stop after N iterations. Default: 0 (unlimited)
#
#     --completion-promise TEXT
#         Stop when TEXT appears in Copilot's final response
#
#     --debug
#         Enable debug logging for both copilot-loop and copilot
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to copilot. If no explicit copilot
#     mode or subcommand is provided, a single positional prompt is treated as
#     `copilot -i "<prompt>"`.
#
# EXAMPLES
#     copilot-loop --max-iteration 5 "implement feature X"
#     copilot-loop --completion-promise "DONE" -- -i "work until done"
#     copilot-loop --max-iteration 3
#
# DEPENDENCIES
#     - copilot (GitHub Copilot CLI)
#     - jq (JSON processor)
#

set -euo pipefail

readonly GITHUB_DIR="${PWD}/.github"
readonly HOOKS_DIR="${GITHUB_DIR}/hooks"
readonly STATE_FILE="${GITHUB_DIR}/copilot-loop.state.json"
readonly HOOK_SCRIPT_PATH="${HOOKS_DIR}/copilot-loop-hook.sh"
readonly HOOK_CONFIG_PATH="${HOOKS_DIR}/copilot-loop.json"
readonly HOOK_SCRIPT_BACKUP="${HOOK_SCRIPT_PATH}.copilot-loop-backup"
readonly HOOK_CONFIG_BACKUP="${HOOK_CONFIG_PATH}.copilot-loop-backup"
readonly HOOK_LOG_FILE="${GITHUB_DIR}/copilot-loop-hook.log"

ITERATION=1
MAX_ITERATIONS=0
COMPLETION_PROMISE=""
COPILOT_ARGS=()
DEBUG=false

log() { [[ "$DEBUG" == "true" ]] && echo "[copilot-loop] $1" >&2 || true; }
log_error() { echo "[copilot-loop] ERROR: $1" >&2; }

copilot_option_takes_value() {
  case "$1" in
    --add-dir|--add-github-mcp-tool|--add-github-mcp-toolset|--additional-mcp-config|--agent|--config-dir|--disable-mcp-server|--effort|--interactive|--log-dir|--log-level|--max-autopilot-continues|--model|--output-format|--plugin-dir|--prompt|--reasoning-effort|--stream)
      return 0
      ;;
    --allow-tool|--allow-url|--alt-screen|--available-tools|--bash-env|--deny-tool|--deny-url|--excluded-tools|--mouse|--resume|--secret-env-vars|--share)
      return 0
      ;;
  esac
  return 1
}

copilot_has_explicit_mode_or_command() {
  local i arg
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    arg="${COPILOT_ARGS[$i]}"
    case "$arg" in
      -p|--prompt|-i|--interactive|--continue|--resume|--resume=*|--acp|--help|-h|-v|--version)
        return 0
        ;;
    esac
    if copilot_option_takes_value "$arg"; then
      ((i++))
      continue
    fi
    if [[ "$arg" != -* ]]; then
      case "$arg" in
        help|init|login|plugin|update|version)
          return 0
          ;;
      esac
      break
    fi
  done
  return 1
}

find_implicit_prompt_index() {
  local i arg prompt_index=""
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    arg="${COPILOT_ARGS[$i]}"
    case "$arg" in
      -p|--prompt|-i|--interactive|--continue|--resume|--resume=*|--acp|--help|-h|-v|--version)
        return 1
        ;;
    esac
    if copilot_option_takes_value "$arg"; then
      ((i++))
      continue
    fi
    if [[ "$arg" != -* ]]; then
      case "$arg" in
        help|init|login|plugin|update|version)
          return 1
          ;;
      esac
      if [[ -n "$prompt_index" ]]; then
        return 1
      fi
      prompt_index="$i"
    fi
  done
  [[ -n "$prompt_index" ]] || return 1
  printf '%s\n' "$prompt_index"
}

prepare_copilot_args() {
  local arg i prompt_index prompt_value
  local has_log_level=false
  local prepared_args=()

  if [[ "$DEBUG" == "true" ]]; then
    for arg in "${COPILOT_ARGS[@]}"; do
      case "$arg" in
        --log-level|--log-level=*)
          has_log_level=true
          break
          ;;
      esac
    done
    if [[ "$has_log_level" != "true" ]]; then
      COPILOT_ARGS=(--log-level debug "${COPILOT_ARGS[@]}")
    fi
  fi

  if copilot_has_explicit_mode_or_command; then
    return
  fi

  prompt_index=$(find_implicit_prompt_index || true)
  [[ -n "$prompt_index" ]] || return

  prompt_value="${COPILOT_ARGS[$prompt_index]}"
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    if [[ "$i" -eq "$prompt_index" ]]; then
      prepared_args+=(-i "$prompt_value")
    else
      prepared_args+=("${COPILOT_ARGS[$i]}")
    fi
  done
  COPILOT_ARGS=("${prepared_args[@]}")
  log "inferred interactive prompt mode from positional prompt"
}

check_dependencies() {
  command -v jq >/dev/null 2>&1 || { log_error "jq is required but not installed."; exit 1; }
  command -v copilot >/dev/null 2>&1 || { log_error "copilot CLI is required but not installed."; exit 1; }
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-iteration)      MAX_ITERATIONS="$2"; shift 2 ;;
      --completion-promise) COMPLETION_PROMISE="$2"; shift 2 ;;
      --debug)              DEBUG=true; shift ;;
      --help|-h)            show_usage; exit 0 ;;
      --)                   shift; COPILOT_ARGS+=("$@"); break ;;
      *)                    COPILOT_ARGS+=("$1"); shift ;;
    esac
  done
}

backup_hook_files() {
  rm -f "$HOOK_SCRIPT_BACKUP" "$HOOK_CONFIG_BACKUP"
  if [[ -f "$HOOK_SCRIPT_PATH" ]]; then
    cp "$HOOK_SCRIPT_PATH" "$HOOK_SCRIPT_BACKUP"
  fi
  if [[ -f "$HOOK_CONFIG_PATH" ]]; then
    cp "$HOOK_CONFIG_PATH" "$HOOK_CONFIG_BACKUP"
  fi
  return 0
}

restore_hook_file() {
  local path="$1"
  local backup="$2"
  if [[ -f "$backup" ]]; then
    mv "$backup" "$path"
  else
    rm -f "$path"
  fi
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  local stop_reason="${3:-}"
  mkdir -p "$GITHUB_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "iteration": $ITERATION,
  "max_iterations": $MAX_ITERATIONS,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [ "$decision" = "null" ]; then echo "null"; else echo "\"$decision\""; fi),
  "hook_called": $hook_called,
  "stop_reason": $(printf '%s' "$stop_reason" | jq -Rs .)
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_iteration() {
  [[ -f "$STATE_FILE" ]] && jq -r '.iteration // 1' "$STATE_FILE" || echo "1"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

read_stop_reason() {
  [[ -f "$STATE_FILE" ]] && jq -r '.stop_reason // ""' "$STATE_FILE" || echo ""
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  backup_hook_files
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${PWD}/.github/copilot-loop.state.json"
DEBUG_FLAG_FILE="${PWD}/.github/copilot-loop.debug"
HOOK_LOG_FILE="${PWD}/.github/copilot-loop-hook.log"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

extract_last_assistant_message() {
  local transcript_path="$1"
  [[ -n "$transcript_path" && -f "$transcript_path" ]] || return 0
  jq -r '
    select(.type == "assistant.message")
    | .data.content // empty
  ' "$transcript_path" 2>/dev/null | tail -n 1 || true
}

INPUT=$(cat)

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcriptPath // empty')
ITERATION=$(echo "$STATE" | jq -r '.iteration // 1')
MAX_ITERATIONS=$(echo "$STATE" | jq -r '.max_iterations // 0')
COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
ASSISTANT_TEXT=$(extract_last_assistant_message "$TRANSCRIPT_PATH")

debug_log "agentStop hook started: iteration=$ITERATION max_iterations=$MAX_ITERATIONS transcript_path=${TRANSCRIPT_PATH:-<none>}"

if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  debug_log "decision=complete iteration=$ITERATION"
  jq '.decision = "complete" | .hook_called = true | .stop_reason = "Completion promise matched."' \
    "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
else
  if [[ "$MAX_ITERATIONS" -gt 0 ]] && [[ "$ITERATION" -ge "$MAX_ITERATIONS" ]]; then
    debug_log "decision=max_reached iteration=$ITERATION/$MAX_ITERATIONS"
    jq '.decision = "max_reached" | .hook_called = true | .stop_reason = "Maximum iterations reached."' \
      "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  else
    NEW_ITERATION=$((ITERATION + 1))
    debug_log "decision=continue iteration=$ITERATION->$NEW_ITERATION"
    jq --argjson iter "$NEW_ITERATION" '.iteration = $iter | .decision = "continue" | .hook_called = true | .stop_reason = ""' \
      "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  fi
fi

PARENT_PID=$(ps -o ppid= "$$" 2>/dev/null | tr -d ' ')
GRANDPARENT_PID=""
if [[ -n "$PARENT_PID" ]]; then
  GRANDPARENT_PID=$(ps -o ppid= "$PARENT_PID" 2>/dev/null | tr -d ' ' || true)
fi

debug_log "sending SIGTERM to parent/copilot processes parent=${PARENT_PID:-<none>} grandparent=${GRANDPARENT_PID:-<none>}"
[[ -n "$PARENT_PID" ]] && kill -TERM "$PARENT_PID" 2>/dev/null || true
[[ -n "$GRANDPARENT_PID" ]] && kill -TERM "$GRANDPARENT_PID" 2>/dev/null || true

exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  cat > "$HOOK_CONFIG_PATH" << 'EOF'
{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": "./.github/hooks/copilot-loop-hook.sh"
      }
    ]
  }
}
EOF

  if [[ "$DEBUG" == "true" ]]; then
    touch "${GITHUB_DIR}/copilot-loop.debug"
  fi
}

cleanup() {
  local exit_code=$?
  trap - EXIT INT TERM
  restore_hook_file "$HOOK_SCRIPT_PATH" "$HOOK_SCRIPT_BACKUP"
  restore_hook_file "$HOOK_CONFIG_PATH" "$HOOK_CONFIG_BACKUP"
  rm -f "${GITHUB_DIR}/copilot-loop.debug"
  rm -f "$HOOK_LOG_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  rm -f "$STATE_FILE"
  rmdir "$GITHUB_DIR" 2>/dev/null || true
  exit "$exit_code"
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) {
        exit
      }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

main() {
  check_dependencies
  parse_args "$@"
  prepare_copilot_args

  [[ "$MAX_ITERATIONS" =~ ^[0-9]+$ ]] || {
    log_error "max iteration must be a non-negative integer."
    exit 1
  }

  trap cleanup EXIT INT TERM

  log "max_iterations=$MAX_ITERATIONS completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script

  while true; do
    write_state "null" "false"
    log "starting copilot (iteration $ITERATION)"

    set +e
    copilot "${COPILOT_ARGS[@]}"
    local copilot_exit_code=$?
    set -e

    local decision hook_called stop_reason
    decision=$(read_decision)
    hook_called=$(read_hook_called)
    ITERATION=$(read_iteration)
    stop_reason=$(read_stop_reason)

    log "copilot exited (code=$copilot_exit_code, decision=$decision, hook=$hook_called, reason=${stop_reason:-<none>})"

    if [[ "$decision" != "continue" ]]; then
      case $copilot_exit_code in
        129|130|137|143)
          if [[ "$hook_called" != "true" ]]; then
            log "interrupted by signal"
            return "$copilot_exit_code"
          fi
          ;;
      esac
    fi

    if [[ "$hook_called" != "true" ]]; then
      log "hook not called; exiting with copilot's status"
      return "$copilot_exit_code"
    fi

    case "$decision" in
      complete|max_reached)
        log "finished after $ITERATION iteration(s): ${stop_reason:-<none>}"
        return 0
        ;;
      continue)
        log "iteration $((ITERATION - 1)) complete, restarting copilot"
        ;;
      *)
        log_error "unexpected decision: $decision"
        return 1
        ;;
    esac
  done
}

main "$@"
