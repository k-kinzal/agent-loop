#!/usr/bin/env bash
#
# cline-watch - Run Cline CLI on file changes
#
# USAGE
#     cline-watch [OPTIONS] [--] [CLINE_ARGS...]
#
# DESCRIPTION
#     Watches directories for file creation and modification, then launches
#     Cline CLI in response. When Cline finishes its work, the watcher returns
#     to monitoring. A cooldown prevents over-triggering from rapid saves.
#
#     Reliable autonomous watching is best with `cline --oneshot ...` or other
#     headless flags such as `--yolo` or `--no-interactive`. Interactive Cline
#     still launches but the watcher cannot continue until that session exits.
#
# OPTIONS
#     --watch-dir DIR
#         Directory to watch recursively (repeatable, optional)
#         When omitted, watch roots are derived from --include patterns
#
#     --include PATTERN
#         Glob pattern to include (repeatable)
#         When omitted, all files under the watch roots are included
#
#     --cooldown N
#         Minimum seconds between Cline runs. Default: 30
#
#     --per-file
#         Run Cline once per changed file instead of once per batch.
#         Default: batch mode (one Cline run for all changed files)
#
#     --completion-promise TEXT
#         Stop the watcher when TEXT appears in Cline output
#         Note: promise matching is best-effort for full-screen TUI sessions
#
#     --max-triggers N
#         Maximum number of triggers before exiting. Default: 0 (unlimited)
#
#     --exclude PATTERN
#         Glob pattern to exclude (repeatable)
#
#     --ignore PATTERN
#         Alias for --exclude
#
#     --debug
#     --loop-debug
#         Enable debug logging
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to cline.
#
# TEMPLATE VARIABLES
#     {{files}}   Replaced with the list of changed file paths (space-separated)
#     {{file}}    Replaced with a single file path (per-file mode)
#
# EXAMPLES
#     cline-watch --watch-dir ./src -- --oneshot "describe what changed in {{files}}"
#     cline-watch --include './src/**/*.ts' -- --oneshot "describe what changed in {{files}}"
#     cline-watch --include '~/.codex/sessions/**/*.jsonl' --per-file -- --oneshot "review {{file}}"
#
# DEPENDENCIES
#     - cline
#     - script (only needed for interactive completion-promise capture)
#     - fswatch (recommended; falls back to find -newer polling)
#

set -euo pipefail

readonly WRAPPER_NAME="cline-watch"
readonly AGENT_NAME="Cline CLI"
: "${CLINE_WATCH_BIN:=cline}"
readonly AGENT_BIN="$CLINE_WATCH_BIN"

WATCH_DIRS=()
INCLUDE_PATTERNS=()
IGNORE_PATTERNS=()
COOLDOWN_SECONDS=30
MAX_TRIGGERS=0
COMPLETION_PROMISE=""
AGENT_ARGS=()
DEBUG=false
TRIGGER_COUNT=0
LAST_RUN_TIMESTAMP=0
SENTINEL_FILE=""
USE_FSWATCH=false
PER_FILE=false
CHANGED_FILES=""
TRANSCRIPT_FILE=""
PRE_RUN_SENTINEL=""
SKIP_WAIT=false

log() {
  [[ "$DEBUG" == "true" ]] && printf '[%s] %s\n' "$WRAPPER_NAME" "$1" >&2 || true
}

log_error() {
  printf '[%s] ERROR: %s\n' "$WRAPPER_NAME" "$1" >&2
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) { exit }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

check_dependencies() {
  command -v "$AGENT_BIN" >/dev/null 2>&1 || {
    log_error "$AGENT_NAME executable not found: $AGENT_BIN"
    exit 1
  }
  if command -v fswatch &>/dev/null; then
    USE_FSWATCH=true
    log "using fswatch for file monitoring"
  else
    log "fswatch not found; falling back to find -newer polling"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --watch-dir)
        [[ $# -ge 2 ]] || { log_error "--watch-dir requires a value."; exit 1; }
        WATCH_DIRS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --include)
        [[ $# -ge 2 ]] || { log_error "--include requires a value."; exit 1; }
        INCLUDE_PATTERNS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --cooldown)
        [[ $# -ge 2 ]] || { log_error "--cooldown requires a value."; exit 1; }
        COOLDOWN_SECONDS="$2"; shift 2 ;;
      --completion-promise|--loop-completion-promise)
        [[ $# -ge 2 ]] || { log_error "$1 requires a value."; exit 1; }
        COMPLETION_PROMISE="$2"; shift 2 ;;
      --max-triggers)
        [[ $# -ge 2 ]] || { log_error "--max-triggers requires a value."; exit 1; }
        MAX_TRIGGERS="$2"; shift 2 ;;
      --per-file)
        PER_FILE=true; shift ;;
      --exclude|--ignore)
        [[ $# -ge 2 ]] || { log_error "$1 requires a value."; exit 1; }
        IGNORE_PATTERNS+=("$2"); shift 2 ;;
      --debug|--loop-debug)
        DEBUG=true; shift ;;
      --help|-h)
        show_usage; exit 0 ;;
      --)
        shift; AGENT_ARGS+=("$@"); break ;;
      *)
        AGENT_ARGS+=("$1"); shift ;;
    esac
  done
}

expand_leading_tilde() {
  local value="$1"
  case "$value" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${value#"~/"}"
      ;;
    *)
      printf '%s\n' "$value"
      ;;
  esac
}

strip_trailing_slashes() {
  local value="$1"
  while [[ "$value" != "/" && "$value" == */ ]]; do
    value="${value%/}"
  done
  printf '%s\n' "$value"
}

pattern_has_glob() {
  [[ "$1" == *[\*\?\[]* ]]
}

derive_watch_dir_from_pattern() {
  local pattern="$1"
  local prefix fallback

  if [[ "$pattern" =~ ^([^*?\[]*) ]]; then
    prefix="${BASH_REMATCH[1]}"
  else
    prefix="$pattern"
  fi

  if [[ -z "$prefix" ]]; then
    if [[ "$pattern" == /* ]]; then
      printf '/\n'
    else
      printf '.\n'
    fi
    return
  fi

  prefix=$(strip_trailing_slashes "$prefix")
  if [[ -z "$prefix" ]]; then
    if [[ "$pattern" == /* ]]; then
      printf '/\n'
    else
      printf '.\n'
    fi
    return
  fi

  if [[ -d "$prefix" ]]; then
    printf '%s\n' "$prefix"
    return
  fi

  if ! pattern_has_glob "$pattern" && [[ -e "$prefix" && ! -d "$prefix" ]]; then
    prefix=$(dirname -- "$prefix")
  fi

  fallback="."
  [[ "$pattern" == /* ]] && fallback="/"

  while [[ ! -d "$prefix" ]]; do
    local parent
    parent=$(dirname -- "$prefix")
    [[ "$parent" == "$prefix" ]] && break
    prefix="$parent"
  done

  if [[ -d "$prefix" ]]; then
    printf '%s\n' "$prefix"
  else
    printf '%s\n' "$fallback"
  fi
}

add_default_watch_dirs() {
  local pattern derived
  if [[ ${#WATCH_DIRS[@]} -eq 0 && ${#INCLUDE_PATTERNS[@]} -eq 0 ]]; then
    WATCH_DIRS+=(".")
  fi
  for pattern in "${INCLUDE_PATTERNS[@]}"; do
    derived=$(derive_watch_dir_from_pattern "$pattern")
    WATCH_DIRS+=("$derived")
  done
}

dedupe_watch_dirs() {
  local dir existing
  local unique=()
  for dir in "${WATCH_DIRS[@]}"; do
    dir=$(strip_trailing_slashes "$dir")
    [[ -z "$dir" ]] && dir="."
    local seen=false
    for existing in "${unique[@]+"${unique[@]}"}"; do
      if [[ "$existing" == "$dir" ]]; then
        seen=true
        break
      fi
    done
    if [[ "$seen" == "false" ]]; then
      unique+=("$dir")
    fi
  done
  WATCH_DIRS=("${unique[@]}")
}

path_to_absolute() {
  local path="$1"
  path=$(expand_leading_tilde "$path")
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    .) printf '%s\n' "$PWD" ;;
    ./*) printf '%s\n' "$PWD/${path#./}" ;;
    *) printf '%s\n' "$PWD/$path" ;;
  esac
}

path_relative_to_pwd() {
  local path="$1"
  local abs_pwd="${PWD%/}"
  local abs_path
  abs_path=$(path_to_absolute "$path")
  if [[ "$abs_path" == "$abs_pwd" ]]; then
    printf '.\n'
  elif [[ "$abs_path" == "$abs_pwd/"* ]]; then
    printf '%s\n' "${abs_path#"$abs_pwd"/}"
  else
    printf '%s\n' "$path"
  fi
}

value_matches_glob_pattern() {
  local prefix="$1"
  local value="$2"
  local remaining="$3"

  if [[ "$remaining" == *'**/'* ]]; then
    local before="${remaining%%'**/'*}"
    local after="${remaining#*'**/'}"
    value_matches_glob_pattern "${prefix}${before}**/" "$value" "$after" && return 0
    value_matches_glob_pattern "${prefix}${before}" "$value" "$after" && return 0
    return 1
  fi

  [[ "$value" == ${prefix}${remaining} ]]
}

path_matches_pattern() {
  local path="$1"
  local pattern="$2"
  local abs_path rel_path basename
  abs_path=$(path_to_absolute "$path")
  rel_path=$(path_relative_to_pwd "$path")
  basename=$(basename -- "$path")
  value_matches_glob_pattern "" "$path" "$pattern" \
    || value_matches_glob_pattern "" "$abs_path" "$pattern" \
    || value_matches_glob_pattern "" "$rel_path" "$pattern" \
    || value_matches_glob_pattern "" "$basename" "$pattern"
}

should_skip_path() {
  local path="$1"
  [[ "$(basename -- "$path")" == ".DS_Store" ]]
}

should_track_path() {
  local path="$1"
  local pattern

  should_skip_path "$path" && return 1

  if [[ ${#INCLUDE_PATTERNS[@]} -gt 0 ]]; then
    local matched=false
    for pattern in "${INCLUDE_PATTERNS[@]}"; do
      if path_matches_pattern "$path" "$pattern"; then
        matched=true
        break
      fi
    done
    [[ "$matched" == "true" ]] || return 1
  fi

  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    if path_matches_pattern "$path" "$pattern"; then
      return 1
    fi
  done

  return 0
}

filter_changed_files() {
  local raw_changes="$1"
  local line filtered=""

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    [[ -f "$line" ]] || continue
    should_track_path "$line" || continue
    filtered+="$line"$'\n'
  done <<< "$raw_changes"

  CHANGED_FILES="${filtered%$'\n'}"
}

validate_config() {
  [[ "$COOLDOWN_SECONDS" =~ ^[0-9]+$ ]] || { log_error "cooldown must be a non-negative integer."; exit 1; }
  [[ "$MAX_TRIGGERS" =~ ^[0-9]+$ ]] || { log_error "max-triggers must be a non-negative integer."; exit 1; }
  add_default_watch_dirs
  dedupe_watch_dirs
  local normalized=()
  for dir in "${WATCH_DIRS[@]}"; do
    dir=$(strip_trailing_slashes "$dir")
    [[ -d "$dir" ]] || { log_error "watch directory does not exist: $dir"; exit 1; }
    normalized+=("$dir")
  done
  WATCH_DIRS=("${normalized[@]}")
}

setup_transcript_file() {
  [[ -n "$COMPLETION_PROMISE" ]] || return 0
  TRANSCRIPT_FILE="$(mktemp "${TMPDIR:-/tmp}/${WRAPPER_NAME}.XXXXXX")"
}

cleanup() {
  local exit_code=$?
  [[ -n "$TRANSCRIPT_FILE" ]] && rm -f "$TRANSCRIPT_FILE"
  [[ -n "$SENTINEL_FILE" ]] && rm -f "$SENTINEL_FILE"
  [[ -n "$PRE_RUN_SENTINEL" ]] && rm -f "$PRE_RUN_SENTINEL"
  exit "$exit_code"
}

transcript_contains_promise() {
  [[ -n "$COMPLETION_PROMISE" ]] || return 1
  [[ -n "$TRANSCRIPT_FILE" && -f "$TRANSCRIPT_FILE" ]] || return 1
  if LC_ALL=C grep -aFq -- "$COMPLETION_PROMISE" "$TRANSCRIPT_FILE"; then
    return 0
  fi
  if command -v strings >/dev/null 2>&1; then
    if LC_ALL=C strings -a -n 1 "$TRANSCRIPT_FILE" | grep -Fq -- "$COMPLETION_PROMISE"; then
      return 0
    fi
  fi
  return 1
}

cooldown_remaining() {
  local now elapsed
  now=$(date +%s)
  elapsed=$((now - LAST_RUN_TIMESTAMP))
  if [[ $elapsed -lt $COOLDOWN_SECONDS ]]; then
    echo $((COOLDOWN_SECONDS - elapsed))
  else
    echo 0
  fi
}

wait_for_changes_fswatch() {
  local fswatch_args=(-r -1 --exclude '\.DS_Store')
  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    fswatch_args+=(--exclude "$pattern")
  done
  fswatch_args+=("${WATCH_DIRS[@]}")
  while true; do
    log "waiting for changes (fswatch)..."
    local changed
    changed=$(fswatch "${fswatch_args[@]}" 2>/dev/null) || return 1
    filter_changed_files "$changed"
    if [[ -n "$CHANGED_FILES" ]]; then
      log "changed files: $(echo "$CHANGED_FILES" | head -5 | tr '\n' ' ')"
      return 0
    fi
    log "changes matched no include/exclude filters, continuing to watch"
  done
}

wait_for_changes_poll() {
  if [[ -z "$SENTINEL_FILE" ]]; then
    SENTINEL_FILE="$(mktemp "${TMPDIR:-/tmp}/${WRAPPER_NAME}.XXXXXX")"
  fi
  touch "$SENTINEL_FILE"
  log "waiting for changes (polling every 5s)..."
  while true; do
    sleep 5
    local find_args=()
    for dir in "${WATCH_DIRS[@]}"; do find_args+=("$dir"); done
    find_args+=(-newer "$SENTINEL_FILE" -not -name '.DS_Store')
    find_args+=(-type f)
    local changed
    changed=$(find "${find_args[@]}" 2>/dev/null || true)
    if [[ -n "$changed" ]]; then
      touch "$SENTINEL_FILE"
      filter_changed_files "$changed"
      if [[ -n "$CHANGED_FILES" ]]; then
        log "changed files: $(echo "$CHANGED_FILES" | head -5 | tr '\n' ' ')"
        return 0
      fi
      log "changes matched no include/exclude filters, continuing to watch"
    fi
  done
}

wait_for_changes() {
  if [[ "$USE_FSWATCH" == "true" ]]; then
    wait_for_changes_fswatch
  else
    wait_for_changes_poll
  fi
}

check_changes_during_run() {
  [[ -z "$PRE_RUN_SENTINEL" ]] && return 1
  local find_args=()
  for dir in "${WATCH_DIRS[@]}"; do find_args+=("$dir"); done
  find_args+=(-newer "$PRE_RUN_SENTINEL" -not -name '.DS_Store')
  find_args+=(-type f)
  local changed
  changed=$(find "${find_args[@]}" 2>/dev/null || true)
  if [[ -n "$changed" ]]; then
    filter_changed_files "$changed"
    if [[ -n "$CHANGED_FILES" ]]; then
      log "changes detected during agent run: $(echo "$CHANGED_FILES" | head -5 | tr '\n' ' ')"
      return 0
    fi
  fi
  return 1
}

expand_template() {
  local files_list="$1"
  local current_file="$2"
  local files_space
  files_space=$(echo "$files_list" | tr '\n' ' ' | sed 's/ $//')
  EXPANDED_ARGS=()
  for arg in "${AGENT_ARGS[@]}"; do
    arg="${arg//\{\{files\}\}/$files_space}"
    arg="${arg//\{\{file\}\}/$current_file}"
    EXPANDED_ARGS+=("$arg")
  done
}

run_agent_once() {
  local -a args=("$@")
  if [[ -n "$TRANSCRIPT_FILE" ]]; then
    : > "$TRANSCRIPT_FILE"
  fi
  set +e
  if [[ -n "$COMPLETION_PROMISE" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      script -q "$TRANSCRIPT_FILE" "$AGENT_BIN" "${args[@]}"
      LAST_EXIT_CODE=$?
    else
      "$AGENT_BIN" "${args[@]}" 2>&1 | tee "$TRANSCRIPT_FILE"
      LAST_EXIT_CODE=${PIPESTATUS[0]}
    fi
  else
    "$AGENT_BIN" "${args[@]}"
    LAST_EXIT_CODE=$?
  fi
  set -e
  log "$AGENT_BIN exited with code $LAST_EXIT_CODE"
}

eval_run_result() {
  case "$LAST_EXIT_CODE" in
    0) ;;
    129|130|137|143)
      log "interrupted by signal"
      WATCHER_EXIT_CODE=$LAST_EXIT_CODE
      return 1
      ;;
    *)
      log "non-zero exit code: $LAST_EXIT_CODE, continuing to watch"
      ;;
  esac
  if transcript_contains_promise; then
    log "completion promise matched after trigger $TRIGGER_COUNT"
    WATCHER_EXIT_CODE=0
    return 1
  fi
  return 0
}

main() {
  parse_args "$@"
  validate_config
  check_dependencies
  setup_transcript_file
  trap cleanup EXIT INT TERM

  log "watch_dirs=${WATCH_DIRS[*]} include_patterns=${INCLUDE_PATTERNS[*]:-<none>} exclude_patterns=${IGNORE_PATTERNS[*]:-<none>} cooldown=${COOLDOWN_SECONDS}s max_triggers=$MAX_TRIGGERS per_file=$PER_FILE completion_promise=${COMPLETION_PROMISE:-<none>}"

  WATCHER_EXIT_CODE=0

  while true; do
    if [[ "$SKIP_WAIT" == "true" ]]; then
      SKIP_WAIT=false
      log "re-triggering immediately for changes during previous run"
    else
      wait_for_changes
    fi

    local remaining
    remaining=$(cooldown_remaining)
    if [[ "$remaining" -gt 0 ]]; then
      log "cooldown active, waiting ${remaining}s"
      sleep "$remaining"
    fi

    TRIGGER_COUNT=$((TRIGGER_COUNT + 1))
    LAST_RUN_TIMESTAMP=$(date +%s)

    # Record pre-run timestamp to detect changes during agent execution
    if [[ -z "$PRE_RUN_SENTINEL" ]]; then
      PRE_RUN_SENTINEL="$(mktemp "${TMPDIR:-/tmp}/${WRAPPER_NAME}-prerun.XXXXXX")"
    fi
    touch "$PRE_RUN_SENTINEL"

    if [[ "$PER_FILE" == "true" ]]; then
      local file_count=0
      while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        file_count=$((file_count + 1))
        log "change detected, running $AGENT_BIN for file $file_count: $file (trigger $TRIGGER_COUNT)"
        expand_template "$file" "$file"
        run_agent_once "${EXPANDED_ARGS[@]}"
        if ! eval_run_result; then return "$WATCHER_EXIT_CODE"; fi
      done <<< "$CHANGED_FILES"
    else
      log "change detected, running $AGENT_BIN (trigger $TRIGGER_COUNT)"
      local first_file
      first_file=$(echo "$CHANGED_FILES" | head -1)
      expand_template "$CHANGED_FILES" "$first_file"
      run_agent_once "${EXPANDED_ARGS[@]}"
      if ! eval_run_result; then return "$WATCHER_EXIT_CODE"; fi
    fi

    if [[ "$MAX_TRIGGERS" -gt 0 ]] && [[ "$TRIGGER_COUNT" -ge "$MAX_TRIGGERS" ]]; then
      log "maximum triggers reached: $TRIGGER_COUNT"
      return 0
    fi

    # Check for file changes that occurred during agent execution
    if check_changes_during_run; then
      SKIP_WAIT=true
      LAST_RUN_TIMESTAMP=$(date +%s)
    fi

    log "trigger $TRIGGER_COUNT complete, resuming watch"
  done
}

main "$@"
