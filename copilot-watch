#!/usr/bin/env bash
#
# copilot-watch - Run GitHub Copilot CLI on file changes
#
# USAGE
#     copilot-watch [OPTIONS] [--] [COPILOT_ARGS...]
#
# DESCRIPTION
#     Watches directories for file creation and modification, then launches
#     GitHub Copilot CLI in response. When Copilot finishes its work, the
#     watcher returns to monitoring. A cooldown prevents over-triggering from
#     rapid saves.
#
#     Uses Copilot's agentStop hook mechanism to ensure Copilot exits after
#     each trigger, supporting both prompt (-p) and interactive modes.
#
# OPTIONS
#     --watch-dir DIR
#         Directory to watch recursively (repeatable, required)
#
#     --cooldown N
#         Minimum seconds between Copilot runs. Default: 30
#
#     --per-file
#         Run Copilot once per changed file instead of once per batch.
#         Default: batch mode (one Copilot run for all changed files)
#
#     --completion-promise TEXT
#         Stop the watcher when TEXT appears in Copilot's final response
#
#     --max-triggers N
#         Maximum number of triggers before exiting. Default: 0 (unlimited)
#
#     --ignore PATTERN
#         Additional glob pattern to ignore (repeatable)
#
#     --debug
#         Enable debug logging
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to copilot.
#
# TEMPLATE VARIABLES
#     {{files}}   Replaced with the list of changed file paths (space-separated)
#     {{file}}    Replaced with a single file path (per-file mode)
#
# EXAMPLES
#     copilot-watch --watch-dir ./src -- -p "describe what changed in {{files}}"
#     copilot-watch --watch-dir ./src --per-file -- -p "review {{file}}"
#     copilot-watch --watch-dir ./src --cooldown 10 -- -i "fix issues"
#
# DEPENDENCIES
#     - copilot (GitHub Copilot CLI)
#     - jq (JSON processor)
#     - fswatch (recommended; falls back to find -newer polling)
#

set -euo pipefail

readonly GITHUB_DIR="${PWD}/.github"
readonly HOOKS_DIR="${GITHUB_DIR}/hooks"
readonly STATE_FILE="${GITHUB_DIR}/copilot-watch.state.json"
readonly HOOK_SCRIPT_PATH="${HOOKS_DIR}/copilot-watch-hook.sh"
readonly HOOK_CONFIG_PATH="${HOOKS_DIR}/copilot-watch.json"
readonly HOOK_LOG_FILE="${GITHUB_DIR}/copilot-watch-hook.log"

WATCH_DIRS=()
IGNORE_PATTERNS=()
COOLDOWN_SECONDS=30
MAX_TRIGGERS=0
COMPLETION_PROMISE=""
COPILOT_ARGS=()
DEBUG=false
TRIGGER_COUNT=0
LAST_RUN_TIMESTAMP=0
SENTINEL_FILE=""
USE_FSWATCH=false
PER_FILE=false
CHANGED_FILES=""
PRE_RUN_SENTINEL=""
SKIP_WAIT=false

log() { [[ "$DEBUG" == "true" ]] && echo "[copilot-watch] $1" >&2 || true; }
log_error() { echo "[copilot-watch] ERROR: $1" >&2; }

check_dependencies() {
  command -v jq >/dev/null 2>&1 || { log_error "jq is required but not installed."; exit 1; }
  command -v copilot >/dev/null 2>&1 || { log_error "copilot CLI is required but not installed."; exit 1; }
  if command -v fswatch &>/dev/null; then
    USE_FSWATCH=true
    log "using fswatch for file monitoring"
  else
    log "fswatch not found; falling back to find -newer polling"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --watch-dir)
        [[ $# -ge 2 ]] || { log_error "--watch-dir requires a value."; exit 1; }
        WATCH_DIRS+=("$2"); shift 2 ;;
      --cooldown)
        [[ $# -ge 2 ]] || { log_error "--cooldown requires a value."; exit 1; }
        COOLDOWN_SECONDS="$2"; shift 2 ;;
      --completion-promise)
        [[ $# -ge 2 ]] || { log_error "--completion-promise requires a value."; exit 1; }
        COMPLETION_PROMISE="$2"; shift 2 ;;
      --max-triggers)
        [[ $# -ge 2 ]] || { log_error "--max-triggers requires a value."; exit 1; }
        MAX_TRIGGERS="$2"; shift 2 ;;
      --per-file)
        PER_FILE=true; shift ;;
      --ignore)
        [[ $# -ge 2 ]] || { log_error "--ignore requires a value."; exit 1; }
        IGNORE_PATTERNS+=("$2"); shift 2 ;;
      --debug)
        DEBUG=true; shift ;;
      --help|-h)
        show_usage; exit 0 ;;
      --)
        shift; COPILOT_ARGS+=("$@"); break ;;
      *)
        COPILOT_ARGS+=("$1"); shift ;;
    esac
  done
}

validate_config() {
  [[ ${#WATCH_DIRS[@]} -gt 0 ]] || { log_error "--watch-dir is required."; exit 1; }
  [[ "$COOLDOWN_SECONDS" =~ ^[0-9]+$ ]] || { log_error "cooldown must be a non-negative integer."; exit 1; }
  [[ "$MAX_TRIGGERS" =~ ^[0-9]+$ ]] || { log_error "max-triggers must be a non-negative integer."; exit 1; }
  local normalized=()
  for dir in "${WATCH_DIRS[@]}"; do
    dir="${dir%/}"
    [[ -d "$dir" ]] || { log_error "watch directory does not exist: $dir"; exit 1; }
    normalized+=("$dir")
  done
  WATCH_DIRS=("${normalized[@]}")
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  mkdir -p "$GITHUB_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [ "$decision" = "null" ]; then echo "null"; else echo "\"$decision\""; fi),
  "hook_called": $hook_called
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${PWD}/.github/copilot-watch.state.json"
DEBUG_FLAG_FILE="${PWD}/.github/copilot-watch.debug"
HOOK_LOG_FILE="${PWD}/.github/copilot-watch-hook.log"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

extract_last_assistant_message() {
  local transcript_path="$1"
  [[ -n "$transcript_path" && -f "$transcript_path" ]] || return 0
  jq -r '
    select(.type == "assistant.message")
    | .data.content // empty
  ' "$transcript_path" 2>/dev/null | tail -n 1 || true
}

INPUT=$(cat)

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcriptPath // empty')
COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
ASSISTANT_TEXT=$(extract_last_assistant_message "$TRANSCRIPT_PATH")

debug_log "agentStop hook started: completion_promise=${COMPLETION_PROMISE:-<none>} transcript_path=${TRANSCRIPT_PATH:-<none>}"

DECISION="done"
if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  DECISION="complete"
  debug_log "decision=complete (completion promise matched)"
else
  debug_log "decision=done"
fi

jq --arg d "$DECISION" '.decision = $d | .hook_called = true' \
  "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

# Terminate Copilot process so the wrapper regains control
PARENT_PID=$(ps -o ppid= "$$" 2>/dev/null | tr -d ' ')
GRANDPARENT_PID=""
if [[ -n "$PARENT_PID" ]]; then
  GRANDPARENT_PID=$(ps -o ppid= "$PARENT_PID" 2>/dev/null | tr -d ' ' || true)
fi

debug_log "sending SIGTERM to parent/copilot processes parent=${PARENT_PID:-<none>} grandparent=${GRANDPARENT_PID:-<none>}"
[[ -n "$PARENT_PID" ]] && kill -TERM "$PARENT_PID" 2>/dev/null || true
[[ -n "$GRANDPARENT_PID" ]] && kill -TERM "$GRANDPARENT_PID" 2>/dev/null || true

printf '%s\n' '{"decision":"allow"}'
exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  cat > "$HOOK_CONFIG_PATH" << 'EOF'
{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": "./.github/hooks/copilot-watch-hook.sh"
      }
    ]
  }
}
EOF

  if [[ "$DEBUG" == "true" ]]; then
    touch "${GITHUB_DIR}/copilot-watch.debug"
  fi
}

cleanup() {
  local exit_code=$?
  rm -f "$HOOK_SCRIPT_PATH"
  rm -f "$HOOK_CONFIG_PATH"
  rm -f "${GITHUB_DIR}/copilot-watch.debug"
  rm -f "$HOOK_LOG_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  rm -f "$STATE_FILE"
  [[ -n "$SENTINEL_FILE" ]] && rm -f "$SENTINEL_FILE"
  [[ -n "$PRE_RUN_SENTINEL" ]] && rm -f "$PRE_RUN_SENTINEL"
  exit "$exit_code"
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) { exit }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

cooldown_remaining() {
  local now elapsed
  now=$(date +%s)
  elapsed=$((now - LAST_RUN_TIMESTAMP))
  if [[ $elapsed -lt $COOLDOWN_SECONDS ]]; then
    echo $((COOLDOWN_SECONDS - elapsed))
  else
    echo 0
  fi
}

wait_for_changes_fswatch() {
  local escaped_github_dir="${GITHUB_DIR//./\\.}"
  local fswatch_args=(-r -1 --exclude "${escaped_github_dir}/" --exclude '\.DS_Store')
  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    fswatch_args+=(--exclude "$pattern")
  done
  fswatch_args+=("${WATCH_DIRS[@]}")
  log "waiting for changes (fswatch)..."
  local changed
  changed=$(fswatch "${fswatch_args[@]}" 2>/dev/null) || return 1
  if [[ -n "$changed" ]]; then
    CHANGED_FILES="$changed"
    log "changed files: $(echo "$changed" | head -5 | tr '\n' ' ')"
    return 0
  fi
  return 1
}

wait_for_changes_poll() {
  if [[ -z "$SENTINEL_FILE" ]]; then
    SENTINEL_FILE="$(mktemp "${TMPDIR:-/tmp}/copilot-watch.XXXXXX")"
  fi
  touch "$SENTINEL_FILE"
  log "waiting for changes (polling every 5s)..."
  while true; do
    sleep 5
    local find_args=()
    for dir in "${WATCH_DIRS[@]}"; do find_args+=("$dir"); done
    find_args+=(-newer "$SENTINEL_FILE" -not -path "${GITHUB_DIR}/*" -not -name '.DS_Store')
    for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
      find_args+=(-not -name "$pattern")
    done
    find_args+=(-type f)
    local changed
    changed=$(find "${find_args[@]}" 2>/dev/null || true)
    if [[ -n "$changed" ]]; then
      touch "$SENTINEL_FILE"
      CHANGED_FILES="$changed"
      log "changed files: $(echo "$changed" | head -5 | tr '\n' ' ')"
      return 0
    fi
  done
}

wait_for_changes() {
  if [[ "$USE_FSWATCH" == "true" ]]; then
    wait_for_changes_fswatch
  else
    wait_for_changes_poll
  fi
}

check_changes_during_run() {
  [[ -z "$PRE_RUN_SENTINEL" ]] && return 1
  local find_args=()
  for dir in "${WATCH_DIRS[@]}"; do find_args+=("$dir"); done
  find_args+=(-newer "$PRE_RUN_SENTINEL" -not -path "${GITHUB_DIR}/*" -not -name '.DS_Store')
  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    find_args+=(-not -name "$pattern")
  done
  find_args+=(-type f)
  local changed
  changed=$(find "${find_args[@]}" 2>/dev/null || true)
  if [[ -n "$changed" ]]; then
    CHANGED_FILES="$changed"
    log "changes detected during copilot run: $(echo "$changed" | head -5 | tr '\n' ' ')"
    return 0
  fi
  return 1
}

expand_template() {
  local files_list="$1"
  local current_file="$2"
  local files_space
  files_space=$(echo "$files_list" | tr '\n' ' ' | sed 's/ $//')
  EXPANDED_ARGS=()
  for arg in "${COPILOT_ARGS[@]}"; do
    arg="${arg//\{\{files\}\}/$files_space}"
    arg="${arg//\{\{file\}\}/$current_file}"
    EXPANDED_ARGS+=("$arg")
  done
}

run_copilot_once() {
  local -a args=("$@")

  write_state "null" "false"

  set +e
  copilot "${args[@]}"
  local copilot_exit_code=$?
  set -e

  local decision hook_called
  decision=$(read_decision)
  hook_called=$(read_hook_called)

  log "copilot exited (code=$copilot_exit_code, decision=$decision, hook=$hook_called)"

  LAST_EXIT_CODE=$copilot_exit_code
  LAST_DECISION=$decision
  LAST_HOOK_CALLED=$hook_called
}

eval_run_result() {
  if [[ "$LAST_HOOK_CALLED" != "true" ]]; then
    case $LAST_EXIT_CODE in
      129|130|137|143)
        if [[ "$LAST_DECISION" != "done" && "$LAST_DECISION" != "complete" ]]; then
          log "interrupted by signal"
          WATCHER_EXIT_CODE=$LAST_EXIT_CODE
          return 1
        fi
        ;;
    esac
    log "hook not called; exiting with copilot's status"
    WATCHER_EXIT_CODE=$LAST_EXIT_CODE
    return 1
  fi

  case "$LAST_DECISION" in
    complete)
      log "completion promise matched after trigger $TRIGGER_COUNT"
      WATCHER_EXIT_CODE=0
      return 1
      ;;
    done)
      return 0
      ;;
    *)
      log_error "unexpected decision: $LAST_DECISION"
      WATCHER_EXIT_CODE=1
      return 1
      ;;
  esac
}

main() {
  for arg in "$@"; do
    [[ "$arg" == "--help" || "$arg" == "-h" ]] && { show_usage; exit 0; }
  done

  check_dependencies
  parse_args "$@"
  validate_config

  if [[ ${#COPILOT_ARGS[@]} -eq 0 ]]; then
    log_error "no arguments provided for copilot. See --help for usage."
    exit 1
  fi

  trap cleanup EXIT INT TERM

  log "watch_dirs=${WATCH_DIRS[*]} cooldown=${COOLDOWN_SECONDS}s max_triggers=$MAX_TRIGGERS per_file=$PER_FILE completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script

  WATCHER_EXIT_CODE=0

  while true; do
    if [[ "$SKIP_WAIT" == "true" ]]; then
      SKIP_WAIT=false
      log "re-triggering immediately for changes during previous run"
    else
      wait_for_changes
    fi

    local remaining
    remaining=$(cooldown_remaining)
    if [[ "$remaining" -gt 0 ]]; then
      log "cooldown active, waiting ${remaining}s"
      sleep "$remaining"
    fi

    TRIGGER_COUNT=$((TRIGGER_COUNT + 1))
    LAST_RUN_TIMESTAMP=$(date +%s)

    # Record pre-run timestamp to detect changes during agent execution
    if [[ -z "$PRE_RUN_SENTINEL" ]]; then
      PRE_RUN_SENTINEL="$(mktemp "${TMPDIR:-/tmp}/copilot-watch-prerun.XXXXXX")"
    fi
    touch "$PRE_RUN_SENTINEL"

    if [[ "$PER_FILE" == "true" ]]; then
      local file_count=0
      while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        file_count=$((file_count + 1))
        log "change detected, running copilot for file $file_count: $file (trigger $TRIGGER_COUNT)"
        expand_template "$CHANGED_FILES" "$file"
        run_copilot_once "${EXPANDED_ARGS[@]}"
        if ! eval_run_result; then return "$WATCHER_EXIT_CODE"; fi
      done <<< "$CHANGED_FILES"
    else
      log "change detected, running copilot (trigger $TRIGGER_COUNT)"
      local first_file
      first_file=$(echo "$CHANGED_FILES" | head -1)
      expand_template "$CHANGED_FILES" "$first_file"
      run_copilot_once "${EXPANDED_ARGS[@]}"
      if ! eval_run_result; then return "$WATCHER_EXIT_CODE"; fi
    fi

    if [[ "$MAX_TRIGGERS" -gt 0 ]] && [[ "$TRIGGER_COUNT" -ge "$MAX_TRIGGERS" ]]; then
      log "maximum triggers reached: $TRIGGER_COUNT"
      return 0
    fi

    # Check for file changes that occurred during agent execution
    if check_changes_during_run; then
      SKIP_WAIT=true
      LAST_RUN_TIMESTAMP=$(date +%s)
    fi

    log "trigger $TRIGGER_COUNT complete, resuming watch"
  done
}

main "$@"
