#!/usr/bin/env bash
#
# copilot-watch - Run GitHub Copilot CLI on file changes
#
# USAGE
#     copilot-watch [OPTIONS] [--] [COPILOT_ARGS...]
#
# DESCRIPTION
#     Watches directories for file creation and modification, then launches
#     GitHub Copilot CLI in response. When Copilot finishes its work, the
#     watcher returns to monitoring. A cooldown prevents over-triggering from
#     rapid saves.
#
#     Uses Copilot's agentStop hook mechanism to ensure Copilot exits after
#     each trigger, supporting both prompt (-p) and interactive modes.
#
# OPTIONS
#     --watch-dir DIR
#         Directory to watch recursively (repeatable, optional)
#         When omitted, watch roots are derived from --include patterns
#
#     --include PATTERN
#         Glob pattern to include (repeatable)
#         When omitted, all files under the watch roots are included
#
#     --cooldown N
#         Minimum seconds between Copilot runs. Default: 30
#
#     --per-file
#         Run Copilot once per changed file instead of once per batch.
#         Default: batch mode (one Copilot run for all changed files)
#
#     --completion-promise TEXT
#         Stop the watcher when TEXT appears in Copilot's final response
#
#     --max-triggers N
#         Maximum number of triggers before exiting. Default: 0 (unlimited)
#
#     --exclude PATTERN
#         Glob pattern to exclude (repeatable)
#
#     --ignore PATTERN
#         Alias for --exclude
#
#     --debug
#         Enable debug logging for both copilot-watch and copilot
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to copilot. If no explicit copilot
#     mode or subcommand is provided, a single positional prompt is treated as
#     `copilot -i "<prompt>"`.
#
# TEMPLATE VARIABLES
#     {{files}}   Replaced with the list of changed file paths (space-separated)
#     {{file}}    Replaced with a single file path (per-file mode)
#
# EXAMPLES
#     copilot-watch --watch-dir ./src -- -p "describe what changed in {{files}}"
#     copilot-watch --include './src/**/*.ts' -- -p "describe what changed in {{files}}"
#     copilot-watch --include '~/.claude/projects/*/*.jsonl' --include '~/.codex/sessions/**/*.jsonl' -- -p "review {{files}}"
#     copilot-watch --watch-dir ./src --exclude '*.log' --cooldown 10 -- -i "fix issues"
#
# DEPENDENCIES
#     - copilot (GitHub Copilot CLI)
#     - jq (JSON processor)
#     - fswatch (recommended; falls back to find -newer polling)
#

set -euo pipefail

readonly GITHUB_DIR="${PWD}/.github"
readonly HOOKS_DIR="${GITHUB_DIR}/hooks"
readonly STATE_FILE="${GITHUB_DIR}/copilot-watch.state.json"
readonly HOOK_SCRIPT_PATH="${HOOKS_DIR}/copilot-watch-hook.sh"
readonly HOOK_CONFIG_PATH="${HOOKS_DIR}/copilot-watch.json"
readonly HOOK_SCRIPT_BACKUP="${HOOK_SCRIPT_PATH}.copilot-watch-backup"
readonly HOOK_CONFIG_BACKUP="${HOOK_CONFIG_PATH}.copilot-watch-backup"
readonly HOOK_LOG_FILE="${GITHUB_DIR}/copilot-watch-hook.log"

WATCH_DIRS=()
INCLUDE_PATTERNS=()
IGNORE_PATTERNS=()
COOLDOWN_SECONDS=30
MAX_TRIGGERS=0
COMPLETION_PROMISE=""
COPILOT_ARGS=()
DEBUG=false
TRIGGER_COUNT=0
LAST_RUN_TIMESTAMP=0
SENTINEL_FILE=""
USE_FSWATCH=false
PER_FILE=false
CHANGED_FILES=""
PRE_RUN_SENTINEL=""
SKIP_WAIT=false

log() { [[ "$DEBUG" == "true" ]] && echo "[copilot-watch] $1" >&2 || true; }
log_error() { echo "[copilot-watch] ERROR: $1" >&2; }

copilot_option_takes_value() {
  case "$1" in
    --add-dir|--add-github-mcp-tool|--add-github-mcp-toolset|--additional-mcp-config|--agent|--config-dir|--disable-mcp-server|--effort|--interactive|--log-dir|--log-level|--max-autopilot-continues|--model|--output-format|--plugin-dir|--prompt|--reasoning-effort|--stream)
      return 0
      ;;
    --allow-tool|--allow-url|--alt-screen|--available-tools|--bash-env|--deny-tool|--deny-url|--excluded-tools|--mouse|--resume|--secret-env-vars|--share)
      return 0
      ;;
  esac
  return 1
}

copilot_has_explicit_mode_or_command() {
  local i arg
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    arg="${COPILOT_ARGS[$i]}"
    case "$arg" in
      -p|--prompt|-i|--interactive|--continue|--resume|--resume=*|--acp|--help|-h|-v|--version)
        return 0
        ;;
    esac
    if copilot_option_takes_value "$arg"; then
      ((i++))
      continue
    fi
    if [[ "$arg" != -* ]]; then
      case "$arg" in
        help|init|login|plugin|update|version)
          return 0
          ;;
      esac
      break
    fi
  done
  return 1
}

find_implicit_prompt_index() {
  local i arg prompt_index=""
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    arg="${COPILOT_ARGS[$i]}"
    case "$arg" in
      -p|--prompt|-i|--interactive|--continue|--resume|--resume=*|--acp|--help|-h|-v|--version)
        return 1
        ;;
    esac
    if copilot_option_takes_value "$arg"; then
      ((i++))
      continue
    fi
    if [[ "$arg" != -* ]]; then
      case "$arg" in
        help|init|login|plugin|update|version)
          return 1
          ;;
      esac
      if [[ -n "$prompt_index" ]]; then
        return 1
      fi
      prompt_index="$i"
    fi
  done
  [[ -n "$prompt_index" ]] || return 1
  printf '%s\n' "$prompt_index"
}

prepare_copilot_args() {
  local arg i prompt_index prompt_value
  local has_log_level=false
  local prepared_args=()

  if [[ "$DEBUG" == "true" ]]; then
    for arg in "${COPILOT_ARGS[@]}"; do
      case "$arg" in
        --log-level|--log-level=*)
          has_log_level=true
          break
          ;;
      esac
    done
    if [[ "$has_log_level" != "true" ]]; then
      COPILOT_ARGS=(--log-level debug "${COPILOT_ARGS[@]}")
    fi
  fi

  if copilot_has_explicit_mode_or_command; then
    return
  fi

  prompt_index=$(find_implicit_prompt_index || true)
  [[ -n "$prompt_index" ]] || return

  prompt_value="${COPILOT_ARGS[$prompt_index]}"
  for ((i=0; i<${#COPILOT_ARGS[@]}; i++)); do
    if [[ "$i" -eq "$prompt_index" ]]; then
      prepared_args+=(-i "$prompt_value")
    else
      prepared_args+=("${COPILOT_ARGS[$i]}")
    fi
  done
  COPILOT_ARGS=("${prepared_args[@]}")
  log "inferred interactive prompt mode from positional prompt"
}

check_dependencies() {
  command -v jq >/dev/null 2>&1 || { log_error "jq is required but not installed."; exit 1; }
  command -v copilot >/dev/null 2>&1 || { log_error "copilot CLI is required but not installed."; exit 1; }
  if command -v fswatch &>/dev/null; then
    USE_FSWATCH=true
    log "using fswatch for file monitoring"
  else
    log "fswatch not found; falling back to find -newer polling"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --watch-dir)
        [[ $# -ge 2 ]] || { log_error "--watch-dir requires a value."; exit 1; }
        WATCH_DIRS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --include)
        [[ $# -ge 2 ]] || { log_error "--include requires a value."; exit 1; }
        INCLUDE_PATTERNS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --cooldown)
        [[ $# -ge 2 ]] || { log_error "--cooldown requires a value."; exit 1; }
        COOLDOWN_SECONDS="$2"; shift 2 ;;
      --completion-promise)
        [[ $# -ge 2 ]] || { log_error "--completion-promise requires a value."; exit 1; }
        COMPLETION_PROMISE="$2"; shift 2 ;;
      --max-triggers)
        [[ $# -ge 2 ]] || { log_error "--max-triggers requires a value."; exit 1; }
        MAX_TRIGGERS="$2"; shift 2 ;;
      --per-file)
        PER_FILE=true; shift ;;
      --exclude|--ignore)
        [[ $# -ge 2 ]] || { log_error "$1 requires a value."; exit 1; }
        IGNORE_PATTERNS+=("$(expand_leading_tilde "$2")"); shift 2 ;;
      --debug)
        DEBUG=true; shift ;;
      --help|-h)
        show_usage; exit 0 ;;
      --)
        shift; COPILOT_ARGS+=("$@"); break ;;
      *)
        COPILOT_ARGS+=("$1"); shift ;;
    esac
  done
}

backup_hook_files() {
  rm -f "$HOOK_SCRIPT_BACKUP" "$HOOK_CONFIG_BACKUP"
  if [[ -f "$HOOK_SCRIPT_PATH" ]]; then
    cp "$HOOK_SCRIPT_PATH" "$HOOK_SCRIPT_BACKUP"
  fi
  if [[ -f "$HOOK_CONFIG_PATH" ]]; then
    cp "$HOOK_CONFIG_PATH" "$HOOK_CONFIG_BACKUP"
  fi
}

restore_hook_file() {
  local path="$1"
  local backup="$2"
  if [[ -f "$backup" ]]; then
    mv "$backup" "$path"
  else
    rm -f "$path"
  fi
}

expand_leading_tilde() {
  local value="$1"
  case "$value" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${value#"~/"}"
      ;;
    *)
      printf '%s\n' "$value"
      ;;
  esac
}

strip_trailing_slashes() {
  local value="$1"
  while [[ "$value" != "/" && "$value" == */ ]]; do
    value="${value%/}"
  done
  printf '%s\n' "$value"
}

pattern_has_glob() {
  [[ "$1" == *[\*\?\[]* ]]
}

derive_watch_dir_from_pattern() {
  local pattern="$1"
  local prefix fallback

  if [[ "$pattern" =~ ^([^*?\[]*) ]]; then
    prefix="${BASH_REMATCH[1]}"
  else
    prefix="$pattern"
  fi

  if [[ -z "$prefix" ]]; then
    if [[ "$pattern" == /* ]]; then
      printf '/\n'
    else
      printf '.\n'
    fi
    return
  fi

  prefix=$(strip_trailing_slashes "$prefix")
  if [[ -z "$prefix" ]]; then
    if [[ "$pattern" == /* ]]; then
      printf '/\n'
    else
      printf '.\n'
    fi
    return
  fi

  if [[ -d "$prefix" ]]; then
    printf '%s\n' "$prefix"
    return
  fi

  if ! pattern_has_glob "$pattern" && [[ -e "$prefix" && ! -d "$prefix" ]]; then
    prefix=$(dirname -- "$prefix")
  fi

  fallback="."
  [[ "$pattern" == /* ]] && fallback="/"

  while [[ ! -d "$prefix" ]]; do
    local parent
    parent=$(dirname -- "$prefix")
    [[ "$parent" == "$prefix" ]] && break
    prefix="$parent"
  done

  if [[ -d "$prefix" ]]; then
    printf '%s\n' "$prefix"
  else
    printf '%s\n' "$fallback"
  fi
}

add_default_watch_dirs() {
  local pattern derived
  if [[ ${#WATCH_DIRS[@]} -eq 0 && ${#INCLUDE_PATTERNS[@]} -eq 0 ]]; then
    WATCH_DIRS+=(".")
  fi
  for pattern in "${INCLUDE_PATTERNS[@]}"; do
    derived=$(derive_watch_dir_from_pattern "$pattern")
    WATCH_DIRS+=("$derived")
  done
}

dedupe_watch_dirs() {
  local dir existing
  local unique=()
  for dir in "${WATCH_DIRS[@]}"; do
    dir=$(strip_trailing_slashes "$dir")
    [[ -z "$dir" ]] && dir="."
    local seen=false
    for existing in "${unique[@]+"${unique[@]}"}"; do
      if [[ "$existing" == "$dir" ]]; then
        seen=true
        break
      fi
    done
    if [[ "$seen" == "false" ]]; then
      unique+=("$dir")
    fi
  done
  WATCH_DIRS=("${unique[@]}")
}

path_to_absolute() {
  local path="$1"
  path=$(expand_leading_tilde "$path")
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    .) printf '%s\n' "$PWD" ;;
    ./*) printf '%s\n' "$PWD/${path#./}" ;;
    *) printf '%s\n' "$PWD/$path" ;;
  esac
}

path_relative_to_pwd() {
  local path="$1"
  local abs_pwd="${PWD%/}"
  local abs_path
  abs_path=$(path_to_absolute "$path")
  if [[ "$abs_path" == "$abs_pwd" ]]; then
    printf '.\n'
  elif [[ "$abs_path" == "$abs_pwd/"* ]]; then
    printf '%s\n' "${abs_path#"$abs_pwd"/}"
  else
    printf '%s\n' "$path"
  fi
}

path_is_within() {
  local path="$1"
  local base="$2"
  local abs_path abs_base
  abs_path=$(path_to_absolute "$path")
  abs_base=$(path_to_absolute "$base")
  [[ "$abs_path" == "$abs_base" || "$abs_path" == "$abs_base/"* ]]
}

value_matches_glob_pattern() {
  local prefix="$1"
  local value="$2"
  local remaining="$3"

  if [[ "$remaining" == *'**/'* ]]; then
    local before="${remaining%%'**/'*}"
    local after="${remaining#*'**/'}"
    value_matches_glob_pattern "${prefix}${before}**/" "$value" "$after" && return 0
    value_matches_glob_pattern "${prefix}${before}" "$value" "$after" && return 0
    return 1
  fi

  [[ "$value" == ${prefix}${remaining} ]]
}

path_matches_pattern() {
  local path="$1"
  local pattern="$2"
  local abs_path rel_path basename
  abs_path=$(path_to_absolute "$path")
  rel_path=$(path_relative_to_pwd "$path")
  basename=$(basename -- "$path")
  value_matches_glob_pattern "" "$path" "$pattern" \
    || value_matches_glob_pattern "" "$abs_path" "$pattern" \
    || value_matches_glob_pattern "" "$rel_path" "$pattern" \
    || value_matches_glob_pattern "" "$basename" "$pattern"
}

should_skip_path() {
  local path="$1"
  [[ "$(basename -- "$path")" == ".DS_Store" ]] && return 0
  path_is_within "$path" "$GITHUB_DIR"
}

should_track_path() {
  local path="$1"
  local pattern

  should_skip_path "$path" && return 1

  if [[ ${#INCLUDE_PATTERNS[@]} -gt 0 ]]; then
    local matched=false
    for pattern in "${INCLUDE_PATTERNS[@]}"; do
      if path_matches_pattern "$path" "$pattern"; then
        matched=true
        break
      fi
    done
    [[ "$matched" == "true" ]] || return 1
  fi

  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    if path_matches_pattern "$path" "$pattern"; then
      return 1
    fi
  done

  return 0
}

filter_changed_files() {
  local raw_changes="$1"
  local line filtered=""

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    [[ -f "$line" ]] || continue
    should_track_path "$line" || continue
    filtered+="$line"$'\n'
  done <<< "$raw_changes"

  CHANGED_FILES="${filtered%$'\n'}"
}

validate_config() {
  [[ "$COOLDOWN_SECONDS" =~ ^[0-9]+$ ]] || { log_error "cooldown must be a non-negative integer."; exit 1; }
  [[ "$MAX_TRIGGERS" =~ ^[0-9]+$ ]] || { log_error "max-triggers must be a non-negative integer."; exit 1; }
  add_default_watch_dirs
  dedupe_watch_dirs
  local normalized=()
  for dir in "${WATCH_DIRS[@]}"; do
    dir=$(strip_trailing_slashes "$dir")
    [[ -d "$dir" ]] || { log_error "watch directory does not exist: $dir"; exit 1; }
    normalized+=("$dir")
  done
  WATCH_DIRS=("${normalized[@]}")
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  mkdir -p "$GITHUB_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [ "$decision" = "null" ]; then echo "null"; else echo "\"$decision\""; fi),
  "hook_called": $hook_called,
  "hook_event": ""
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

read_hook_event() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_event // ""' "$STATE_FILE" || echo ""
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  backup_hook_files
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${PWD}/.github/copilot-watch.state.json"
DEBUG_FLAG_FILE="${PWD}/.github/copilot-watch.debug"
HOOK_LOG_FILE="${PWD}/.github/copilot-watch-hook.log"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

extract_last_assistant_message() {
  local transcript_path="$1"
  [[ -n "$transcript_path" && -f "$transcript_path" ]] || return 0
  jq -r '
    select(.type == "assistant.message")
    | .data.content // empty
  ' "$transcript_path" 2>/dev/null | tail -n 1 || true
}

INPUT=$(cat)

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

HOOK_EVENT="${COPILOT_WATCH_HOOK_EVENT:-agentStop}"

if [[ "$HOOK_EVENT" == "errorOccurred" ]]; then
  ERROR_NAME=$(echo "$INPUT" | jq -r '.error.name // "Error"')
  ERROR_MESSAGE=$(echo "$INPUT" | jq -r '.error.message // ""')
  debug_log "errorOccurred hook started: error=${ERROR_NAME}: ${ERROR_MESSAGE:-<none>}"
  jq --arg event "$HOOK_EVENT" '.decision = "done" | .hook_called = true | .hook_event = $event' \
    "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  exit 0
else
  TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcriptPath // empty')
  COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
  ASSISTANT_TEXT=$(extract_last_assistant_message "$TRANSCRIPT_PATH")

  debug_log "agentStop hook started: completion_promise=${COMPLETION_PROMISE:-<none>} transcript_path=${TRANSCRIPT_PATH:-<none>}"

  DECISION="done"
  if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
    DECISION="complete"
    debug_log "decision=complete (completion promise matched)"
  else
    debug_log "decision=done"
  fi

  jq --arg d "$DECISION" --arg event "$HOOK_EVENT" '.decision = $d | .hook_called = true | .hook_event = $event' \
    "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
fi

# Terminate Copilot process so the wrapper regains control
PARENT_PID=$(ps -o ppid= "$$" 2>/dev/null | tr -d ' ')
GRANDPARENT_PID=""
if [[ -n "$PARENT_PID" ]]; then
  GRANDPARENT_PID=$(ps -o ppid= "$PARENT_PID" 2>/dev/null | tr -d ' ' || true)
fi

debug_log "sending SIGTERM to parent/copilot processes parent=${PARENT_PID:-<none>} grandparent=${GRANDPARENT_PID:-<none>}"
[[ -n "$PARENT_PID" ]] && kill -TERM "$PARENT_PID" 2>/dev/null || true
[[ -n "$GRANDPARENT_PID" ]] && kill -TERM "$GRANDPARENT_PID" 2>/dev/null || true

exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  cat > "$HOOK_CONFIG_PATH" << 'EOF'
{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "env": {
          "COPILOT_WATCH_HOOK_EVENT": "agentStop"
        },
        "bash": "./.github/hooks/copilot-watch-hook.sh"
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "env": {
          "COPILOT_WATCH_HOOK_EVENT": "errorOccurred"
        },
        "bash": "./.github/hooks/copilot-watch-hook.sh"
      }
    ]
  }
}
EOF

  if [[ "$DEBUG" == "true" ]]; then
    touch "${GITHUB_DIR}/copilot-watch.debug"
  fi
}

cleanup() {
  local exit_code=$?
  trap - EXIT INT TERM
  restore_hook_file "$HOOK_SCRIPT_PATH" "$HOOK_SCRIPT_BACKUP"
  restore_hook_file "$HOOK_CONFIG_PATH" "$HOOK_CONFIG_BACKUP"
  rm -f "${GITHUB_DIR}/copilot-watch.debug"
  rm -f "$HOOK_LOG_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  rm -f "$STATE_FILE"
  [[ -n "$SENTINEL_FILE" ]] && rm -f "$SENTINEL_FILE"
  [[ -n "$PRE_RUN_SENTINEL" ]] && rm -f "$PRE_RUN_SENTINEL"
  rmdir "$GITHUB_DIR" 2>/dev/null || true
  exit "$exit_code"
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) { exit }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

cooldown_remaining() {
  local now elapsed
  now=$(date +%s)
  elapsed=$((now - LAST_RUN_TIMESTAMP))
  if [[ $elapsed -lt $COOLDOWN_SECONDS ]]; then
    echo $((COOLDOWN_SECONDS - elapsed))
  else
    echo 0
  fi
}

wait_for_changes_fswatch() {
  local fswatch_args=(-r -1)
  # Escape dots in absolute path for fswatch regex
  local escaped_github_dir="${GITHUB_DIR//./\\.}"
  fswatch_args+=(--exclude "${escaped_github_dir}/")
  fswatch_args+=(--exclude '\.DS_Store')
  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    fswatch_args+=(--exclude "$pattern")
  done
  fswatch_args+=("${WATCH_DIRS[@]}")

  while true; do
    log "waiting for changes (fswatch)..."
    local changed
    changed=$(fswatch "${fswatch_args[@]}" 2>/dev/null) || return 1
    filter_changed_files "$changed"
    if [[ -n "$CHANGED_FILES" ]]; then
      log "changed files: $(echo "$CHANGED_FILES" | head -5 | tr '\n' ' ')"
      return 0
    fi
    log "changes matched no include/exclude filters, continuing to watch"
  done
}

wait_for_changes_poll() {
  if [[ -z "$SENTINEL_FILE" ]]; then
    SENTINEL_FILE="$(mktemp "${TMPDIR:-/tmp}/copilot-watch.XXXXXX")"
  fi
  touch "$SENTINEL_FILE"
  log "waiting for changes (polling every 5s)..."
  while true; do
    sleep 5
    local find_args=()
    for dir in "${WATCH_DIRS[@]}"; do find_args+=("$dir"); done
    find_args+=(-newer "$SENTINEL_FILE" -not -path "${GITHUB_DIR}/*" -not -name '.DS_Store')
    find_args+=(-type f)
    local changed
    changed=$(find "${find_args[@]}" 2>/dev/null || true)
    if [[ -n "$changed" ]]; then
      touch "$SENTINEL_FILE"
      filter_changed_files "$changed"
      if [[ -n "$CHANGED_FILES" ]]; then
        log "changed files: $(echo "$CHANGED_FILES" | head -5 | tr '\n' ' ')"
        return 0
      fi
      log "changes matched no include/exclude filters, continuing to watch"
    fi
  done
}

wait_for_changes() {
  if [[ "$USE_FSWATCH" == "true" ]]; then
    wait_for_changes_fswatch
  else
    wait_for_changes_poll
  fi
}

check_changes_during_run() {
  [[ -z "$PRE_RUN_SENTINEL" ]] && return 1
  local find_args=()
  for dir in "${WATCH_DIRS[@]}"; do find_args+=("$dir"); done
  find_args+=(-newer "$PRE_RUN_SENTINEL" -not -path "${GITHUB_DIR}/*" -not -name '.DS_Store')
  find_args+=(-type f)
  local changed
  changed=$(find "${find_args[@]}" 2>/dev/null || true)
  if [[ -n "$changed" ]]; then
    filter_changed_files "$changed"
    if [[ -n "$CHANGED_FILES" ]]; then
      log "changes detected during copilot run: $(echo "$CHANGED_FILES" | head -5 | tr '\n' ' ')"
      return 0
    fi
  fi
  return 1
}

expand_template() {
  local files_list="$1"
  local current_file="$2"
  local files_space
  files_space=$(echo "$files_list" | tr '\n' ' ' | sed 's/ $//')
  EXPANDED_ARGS=()
  for arg in "${COPILOT_ARGS[@]}"; do
    arg="${arg//\{\{files\}\}/$files_space}"
    arg="${arg//\{\{file\}\}/$current_file}"
    EXPANDED_ARGS+=("$arg")
  done
}

run_copilot_once() {
  local -a args=("$@")

  write_state "null" "false"

  set +e
  copilot "${args[@]}"
  local copilot_exit_code=$?
  set -e

  local decision hook_called hook_event
  decision=$(read_decision)
  hook_called=$(read_hook_called)
  hook_event=$(read_hook_event)

  log "copilot exited (code=$copilot_exit_code, decision=$decision, hook=$hook_called, event=${hook_event:-<none>})"

  LAST_EXIT_CODE=$copilot_exit_code
  LAST_DECISION=$decision
  LAST_HOOK_CALLED=$hook_called
  LAST_HOOK_EVENT=$hook_event
}

eval_run_result() {
  if [[ "$LAST_HOOK_CALLED" != "true" ]]; then
    case $LAST_EXIT_CODE in
      129|130|137|143)
        if [[ "$LAST_DECISION" != "done" && "$LAST_DECISION" != "complete" ]]; then
          log "interrupted by signal"
          WATCHER_EXIT_CODE=$LAST_EXIT_CODE
          return 1
        fi
        ;;
    esac
    log "hook not called; exiting with copilot's status"
    WATCHER_EXIT_CODE=$LAST_EXIT_CODE
    return 1
  fi

  case "$LAST_HOOK_EVENT" in
    errorOccurred)
      log "copilot reported an execution error; continuing to watch"
      ;;
  esac

  case "$LAST_DECISION" in
    complete)
      log "completion promise matched after trigger $TRIGGER_COUNT"
      WATCHER_EXIT_CODE=0
      return 1
      ;;
    done)
      return 0
      ;;
    *)
      log_error "unexpected decision: $LAST_DECISION"
      WATCHER_EXIT_CODE=1
      return 1
      ;;
  esac
}

main() {
  for arg in "$@"; do
    [[ "$arg" == "--help" || "$arg" == "-h" ]] && { show_usage; exit 0; }
  done

  check_dependencies
  parse_args "$@"
  validate_config
  prepare_copilot_args

  if [[ ${#COPILOT_ARGS[@]} -eq 0 ]]; then
    log_error "no arguments provided for copilot. See --help for usage."
    exit 1
  fi

  trap cleanup EXIT INT TERM

  log "watch_dirs=${WATCH_DIRS[*]} include_patterns=${INCLUDE_PATTERNS[*]:-<none>} exclude_patterns=${IGNORE_PATTERNS[*]:-<none>} cooldown=${COOLDOWN_SECONDS}s max_triggers=$MAX_TRIGGERS per_file=$PER_FILE completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script

  WATCHER_EXIT_CODE=0

  while true; do
    if [[ "$SKIP_WAIT" == "true" ]]; then
      SKIP_WAIT=false
      log "re-triggering immediately for changes during previous run"
    else
      wait_for_changes
    fi

    local remaining
    remaining=$(cooldown_remaining)
    if [[ "$remaining" -gt 0 ]]; then
      log "cooldown active, waiting ${remaining}s"
      sleep "$remaining"
    fi

    TRIGGER_COUNT=$((TRIGGER_COUNT + 1))
    LAST_RUN_TIMESTAMP=$(date +%s)

    # Record pre-run timestamp to detect changes during agent execution
    if [[ -z "$PRE_RUN_SENTINEL" ]]; then
      PRE_RUN_SENTINEL="$(mktemp "${TMPDIR:-/tmp}/copilot-watch-prerun.XXXXXX")"
    fi
    touch "$PRE_RUN_SENTINEL"

    if [[ "$PER_FILE" == "true" ]]; then
      local file_count=0
      while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        file_count=$((file_count + 1))
        log "change detected, running copilot for file $file_count: $file (trigger $TRIGGER_COUNT)"
        expand_template "$file" "$file"
        run_copilot_once "${EXPANDED_ARGS[@]}"
        if ! eval_run_result; then return "$WATCHER_EXIT_CODE"; fi
      done <<< "$CHANGED_FILES"
    else
      log "change detected, running copilot (trigger $TRIGGER_COUNT)"
      local first_file
      first_file=$(echo "$CHANGED_FILES" | head -1)
      expand_template "$CHANGED_FILES" "$first_file"
      run_copilot_once "${EXPANDED_ARGS[@]}"
      if ! eval_run_result; then return "$WATCHER_EXIT_CODE"; fi
    fi

    if [[ "$MAX_TRIGGERS" -gt 0 ]] && [[ "$TRIGGER_COUNT" -ge "$MAX_TRIGGERS" ]]; then
      log "maximum triggers reached: $TRIGGER_COUNT"
      return 0
    fi

    # Check for file changes that occurred during agent execution
    if check_changes_during_run; then
      SKIP_WAIT=true
      LAST_RUN_TIMESTAMP=$(date +%s)
    fi

    log "trigger $TRIGGER_COUNT complete, resuming watch"
  done
}

main "$@"
