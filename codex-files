#!/usr/bin/env bash
#
# codex-files - Run Codex CLI once per file from a file list
#
# USAGE
#     codex-files [OPTIONS] [--] [CODEX_ARGS...]
#
# DESCRIPTION
#     Reads newline-delimited file paths from one or more file lists and
#     launches Codex CLI once per line. Codex runs under a managed Stop hook
#     so the wrapper regains control after each completed turn and starts the
#     next file in a fresh session.
#
#     Relative paths in the file list are resolved from the current working
#     directory.
#
# OPTIONS
#     --files-from PATH
#         Read newline-delimited file paths from PATH. Repeatable.
#         Use `-` to read from stdin. When omitted, stdin is used if available.
#
#     --include PATTERN
#         Glob pattern to include (repeatable)
#         When omitted, all listed files are included
#
#     --exclude PATTERN
#         Glob pattern to exclude (repeatable)
#
#     --ignore PATTERN
#         Alias for --exclude
#
#     --max-files N
#         Stop after N matching files. Default: 0 (all)
#
#     --completion-promise TEXT
#     --loop-completion-promise TEXT
#         Stop after a run whose final response contains TEXT
#
#     --debug
#     --loop-debug
#         Enable debug logging
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to codex.
#
# TEMPLATE VARIABLES
#     {{file}}    Replaced with the current file path
#     {{files}}   Replaced with the current file path for compatibility with
#                 `*-watch` prompts
#
# EXAMPLES
#     codex-files --files-from files.txt -- exec "review {{file}}"
#     printf '%s\n' src/a.ts src/b.ts | codex-files -- exec "fix {{file}}"
#     codex-files --files-from files.txt --max-files 10 -- exec "analyze {{file}}"
#
# DEPENDENCIES
#     - bash
#     - codex
#     - jq
#

set -euo pipefail

readonly WRAPPER_NAME="codex-files"
readonly AGENT_NAME="Codex CLI"
: "${CODEX_FILES_BIN:=codex}"
readonly AGENT_BIN="$CODEX_FILES_BIN"

FILES_FROM=()
INCLUDE_PATTERNS=()
IGNORE_PATTERNS=()
MAX_FILES=0
COMPLETION_PROMISE=""
DEBUG=false
AGENT_ARGS=()
INPUT_FILES=()
FAILED_RUNS=0
PROCESSED_COUNT=0
PROJECT_DIR=""
CODEX_DIR=""
HOOKS_DIR=""
STATE_FILE=""
HOOKS_FILE=""
HOOKS_FILE_BACKUP=""
HOOK_SCRIPT_PATH=""
DEBUG_FLAG_FILE=""
HOOK_LOG_FILE=""
HOOKS_MODIFIED=false

log() {
  [[ "$DEBUG" == "true" ]] && printf '[%s] %s\n' "$WRAPPER_NAME" "$1" >&2 || true
}

log_error() {
  printf '[%s] ERROR: %s\n' "$WRAPPER_NAME" "$1" >&2
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) {
        exit
      }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

check_dependencies() {
  command -v "$AGENT_BIN" >/dev/null 2>&1 || {
    log_error "$AGENT_NAME executable not found: $AGENT_BIN"
    exit 1
  }

  command -v jq >/dev/null 2>&1 || {
    log_error "jq is required but not installed."
    exit 1
  }
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --files-from)
        [[ $# -ge 2 ]] || {
          log_error "--files-from requires a value."
          exit 1
        }
        FILES_FROM+=("$(expand_leading_tilde "$2")")
        shift 2
        ;;
      --include)
        [[ $# -ge 2 ]] || {
          log_error "--include requires a value."
          exit 1
        }
        INCLUDE_PATTERNS+=("$(expand_leading_tilde "$2")")
        shift 2
        ;;
      --exclude|--ignore)
        [[ $# -ge 2 ]] || {
          log_error "$1 requires a value."
          exit 1
        }
        IGNORE_PATTERNS+=("$(expand_leading_tilde "$2")")
        shift 2
        ;;
      --max-files)
        [[ $# -ge 2 ]] || {
          log_error "--max-files requires a value."
          exit 1
        }
        MAX_FILES="$2"
        shift 2
        ;;
      --completion-promise|--loop-completion-promise)
        [[ $# -ge 2 ]] || {
          log_error "$1 requires a value."
          exit 1
        }
        COMPLETION_PROMISE="$2"
        shift 2
        ;;
      --debug|--loop-debug)
        DEBUG=true
        shift
        ;;
      --help|-h)
        show_usage
        exit 0
        ;;
      --)
        shift
        AGENT_ARGS+=("$@")
        break
        ;;
      *)
        AGENT_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

expand_leading_tilde() {
  local value="$1"
  case "$value" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s\n' "$HOME/${value#"~/"}"
      ;;
    *)
      printf '%s\n' "$value"
      ;;
  esac
}

path_to_absolute() {
  local path="$1"
  path=$(expand_leading_tilde "$path")
  case "$path" in
    /*)
      printf '%s\n' "$path"
      ;;
    .)
      printf '%s\n' "$PWD"
      ;;
    ./*)
      printf '%s\n' "$PWD/${path#./}"
      ;;
    *)
      printf '%s\n' "$PWD/$path"
      ;;
  esac
}

path_relative_to_pwd() {
  local path="$1"
  local abs_pwd="${PWD%/}"
  local abs_path
  abs_path=$(path_to_absolute "$path")
  if [[ "$abs_path" == "$abs_pwd" ]]; then
    printf '.\n'
  elif [[ "$abs_path" == "$abs_pwd/"* ]]; then
    printf '%s\n' "${abs_path#"$abs_pwd"/}"
  else
    printf '%s\n' "$path"
  fi
}

value_matches_glob_pattern() {
  local prefix="$1"
  local value="$2"
  local remaining="$3"

  if [[ "$remaining" == *'**/'* ]]; then
    local before="${remaining%%'**/'*}"
    local after="${remaining#*'**/'}"
    value_matches_glob_pattern "${prefix}${before}**/" "$value" "$after" && return 0
    value_matches_glob_pattern "${prefix}${before}" "$value" "$after" && return 0
    return 1
  fi

  [[ "$value" == ${prefix}${remaining} ]]
}

path_matches_pattern() {
  local path="$1"
  local pattern="$2"
  local abs_path rel_path basename
  abs_path=$(path_to_absolute "$path")
  rel_path=$(path_relative_to_pwd "$path")
  basename=$(basename -- "$path")
  value_matches_glob_pattern "" "$path" "$pattern" \
    || value_matches_glob_pattern "" "$abs_path" "$pattern" \
    || value_matches_glob_pattern "" "$rel_path" "$pattern" \
    || value_matches_glob_pattern "" "$basename" "$pattern"
}

should_skip_path() {
  local path="$1"
  [[ "$(basename -- "$path")" == ".DS_Store" ]]
}

should_track_path() {
  local path="$1"
  local pattern

  should_skip_path "$path" && return 1

  if [[ ${#INCLUDE_PATTERNS[@]} -gt 0 ]]; then
    local matched=false
    for pattern in "${INCLUDE_PATTERNS[@]}"; do
      if path_matches_pattern "$path" "$pattern"; then
        matched=true
        break
      fi
    done
    [[ "$matched" == "true" ]] || return 1
  fi

  for pattern in "${IGNORE_PATTERNS[@]+"${IGNORE_PATTERNS[@]}"}"; do
    if path_matches_pattern "$path" "$pattern"; then
      return 1
    fi
  done

  return 0
}

process_file_list() {
  local source="$1"
  local line path

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    [[ -n "$line" ]] || continue
    path=$(expand_leading_tilde "$line")
    if [[ ! -f "$path" ]]; then
      log "skipping missing or non-regular file from $source: $line"
      continue
    fi
    if ! should_track_path "$path"; then
      log "skipping filtered file from $source: $path"
      continue
    fi
    INPUT_FILES+=("$path")
  done
}

collect_input_files() {
  local source

  if [[ ${#FILES_FROM[@]} -eq 0 ]]; then
    if [[ -t 0 ]]; then
      log_error "no file list provided. Use --files-from PATH or pipe newline-delimited paths on stdin."
      exit 1
    fi
    FILES_FROM=("-")
  fi

  for source in "${FILES_FROM[@]}"; do
    if [[ "$source" == "-" ]]; then
      log "reading file list from stdin"
      process_file_list "stdin"
    else
      [[ -f "$source" ]] || {
        log_error "file list does not exist: $source"
        exit 1
      }
      log "reading file list from $source"
      process_file_list "$source" < "$source"
    fi
  done

  [[ ${#INPUT_FILES[@]} -gt 0 ]] || {
    log_error "no matching files found in the provided file list."
    exit 1
  }
}

validate_config() {
  [[ "$MAX_FILES" =~ ^[0-9]+$ ]] || {
    log_error "max-files must be a non-negative integer."
    exit 1
  }
}

resolve_project_dir() {
  local candidate="$PWD"
  local i arg

  for ((i = 0; i < ${#AGENT_ARGS[@]}; i++)); do
    arg="${AGENT_ARGS[$i]}"
    case "$arg" in
      -C|--cd)
        if (( i + 1 < ${#AGENT_ARGS[@]} )); then
          candidate="${AGENT_ARGS[$((i + 1))]}"
        fi
        ;;
      --cd=*)
        candidate="${arg#--cd=}"
        ;;
    esac
  done

  candidate=$(path_to_absolute "$candidate")
  PROJECT_DIR=$(cd "$candidate" 2>/dev/null && pwd) || {
    log_error "cannot access codex working directory: $candidate"
    exit 1
  }
}

initialize_paths() {
  CODEX_DIR="${PROJECT_DIR}/.codex"
  HOOKS_DIR="${CODEX_DIR}/hooks"
  STATE_FILE="${CODEX_DIR}/codex-files.state.json"
  HOOKS_FILE="${CODEX_DIR}/hooks.json"
  HOOKS_FILE_BACKUP="${HOOKS_FILE}.codex-files-backup"
  HOOK_SCRIPT_PATH="${HOOKS_DIR}/codex-files-hook.sh"
  DEBUG_FLAG_FILE="${CODEX_DIR}/codex-files.debug"
  HOOK_LOG_FILE="${CODEX_DIR}/codex-files-hook.log"
}

write_state() {
  local decision="${1:-null}"
  local hook_called="${2:-false}"
  local stop_reason="${3:-}"

  mkdir -p "$CODEX_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [[ "$decision" == "null" ]]; then echo "null"; else printf '"%s"' "$decision"; fi),
  "hook_called": $hook_called,
  "stop_reason": $(printf '%s' "$stop_reason" | jq -Rs .)
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

read_stop_reason() {
  [[ -f "$STATE_FILE" ]] && jq -r '.stop_reason // ""' "$STATE_FILE" || echo ""
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

CODEX_DIR="$(cd "$(dirname "$0")/.." && pwd)"
STATE_FILE="${CODEX_DIR}/codex-files.state.json"
DEBUG_FLAG_FILE="${CODEX_DIR}/codex-files.debug"
HOOK_LOG_FILE="${CODEX_DIR}/codex-files-hook.log"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

INPUT=$(cat)

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')
COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
LAST_ASSISTANT_MESSAGE=$(echo "$INPUT" | jq -r '.last_assistant_message // empty')
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false')
ASSISTANT_TEXT="$LAST_ASSISTANT_MESSAGE"

debug_log "Stop hook started: completion_promise=${COMPLETION_PROMISE:-<none>} stop_hook_active=$STOP_HOOK_ACTIVE transcript_path=${TRANSCRIPT_PATH:-<none>}"

if [[ -z "$ASSISTANT_TEXT" ]] && [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
  ASSISTANT_TEXT=$(jq -r '
    select(.type == "assistant")
    | .message.content[]?
    | select(.type == "text")
    | .text // empty
  ' "$TRANSCRIPT_PATH" 2>/dev/null | tail -n 1 || true)
fi

DECISION="done"
STOP_REASON=""

if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  DECISION="complete"
  STOP_REASON="Completion promise matched."
  debug_log "decision=complete"
else
  debug_log "decision=done"
fi

jq --arg decision "$DECISION" --arg reason "$STOP_REASON" \
  '.decision = $decision | .hook_called = true | .stop_reason = $reason' \
  "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

if [[ -n "$STOP_REASON" ]]; then
  jq -cn --arg reason "$STOP_REASON" '{"continue": false, "stopReason": $reason}'
else
  jq -cn '{"continue": false}'
fi

debug_log "sending SIGTERM to codex process (PID=$PPID)"
kill -TERM "$PPID" 2>/dev/null || true
exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  if [[ "$DEBUG" == "true" ]]; then
    touch "$DEBUG_FLAG_FILE"
  fi
}

merge_hooks_file() {
  local tmp_file

  mkdir -p "$CODEX_DIR"

  if [[ -f "$HOOKS_FILE" ]]; then
    cp "$HOOKS_FILE" "$HOOKS_FILE_BACKUP"
  fi

  if [[ -f "$HOOKS_FILE" ]]; then
    tmp_file=$(mktemp "${TMPDIR:-/tmp}/${WRAPPER_NAME}.hooks.XXXXXX")
    jq --arg cmd "$HOOK_SCRIPT_PATH" '
      .hooks = (.hooks // {})
      | .hooks.Stop = (
          ((.hooks.Stop // [])
            | map(
                .hooks = ((.hooks // []) | map(select(.command != $cmd)))
              )
            | map(select((.hooks | length) > 0))
          )
          + [{"hooks": [{"type": "command", "command": $cmd, "timeout": 30}]}]
        )
    ' "$HOOKS_FILE" > "$tmp_file"
    mv "$tmp_file" "$HOOKS_FILE"
  else
    jq -n --arg cmd "$HOOK_SCRIPT_PATH" '
      {
        hooks: {
          Stop: [
            {
              hooks: [
                {
                  type: "command",
                  command: $cmd,
                  timeout: 30
                }
              ]
            }
          ]
        }
      }
    ' > "$HOOKS_FILE"
  fi

  HOOKS_MODIFIED=true
  log "hook registered in $HOOKS_FILE"
}

restore_hooks_file() {
  [[ "$HOOKS_MODIFIED" == "true" ]] || return 0

  if [[ -f "$HOOKS_FILE_BACKUP" ]]; then
    mv "$HOOKS_FILE_BACKUP" "$HOOKS_FILE"
  else
    rm -f "$HOOKS_FILE"
  fi

  HOOKS_MODIFIED=false
}

cleanup() {
  local exit_code=$?

  rm -f "$HOOK_SCRIPT_PATH"
  rm -f "$DEBUG_FLAG_FILE"
  rm -f "$HOOK_LOG_FILE"
  restore_hooks_file
  rm -f "$STATE_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  rmdir "$CODEX_DIR" 2>/dev/null || true
  exit "$exit_code"
}

expand_template() {
  local current_file="$1"
  EXPANDED_ARGS=()
  for arg in "${AGENT_ARGS[@]}"; do
    arg="${arg//\{\{files\}\}/$current_file}"
    arg="${arg//\{\{file\}\}/$current_file}"
    EXPANDED_ARGS+=("$arg")
  done
}

run_agent_once() {
  local -a args=("$@")
  local -a run_args=(-c "features.codex_hooks=true" "${args[@]}")
  local codex_exit_code decision hook_called stop_reason

  write_state "null" "false"

  set +e
  "$AGENT_BIN" "${run_args[@]}"
  codex_exit_code=$?
  set -e

  decision=$(read_decision)
  hook_called=$(read_hook_called)
  stop_reason=$(read_stop_reason)

  log "$AGENT_BIN exited (code=$codex_exit_code, decision=$decision, hook=$hook_called, reason=${stop_reason:-<none>})"

  LAST_EXIT_CODE=$codex_exit_code
  LAST_DECISION=$decision
  LAST_HOOK_CALLED=$hook_called
}

eval_run_result() {
  if [[ "$LAST_HOOK_CALLED" != "true" ]]; then
    case "$LAST_EXIT_CODE" in
      129|130|137|143)
        log "interrupted by signal while processing $CURRENT_FILE"
        WRAPPER_EXIT_CODE=$LAST_EXIT_CODE
        return 1
        ;;
      *)
        log "hook not called; exiting with codex's status"
        WRAPPER_EXIT_CODE=$LAST_EXIT_CODE
        return 1
        ;;
    esac
  fi

  case "$LAST_EXIT_CODE" in
    0|129|130|137|143)
      ;;
    *)
      FAILED_RUNS=$((FAILED_RUNS + 1))
      log "non-zero exit code while processing $CURRENT_FILE: $LAST_EXIT_CODE"
      ;;
  esac

  case "$LAST_DECISION" in
    complete)
      log "completion promise matched after file $PROCESSED_COUNT"
      if [[ "$FAILED_RUNS" -gt 0 ]]; then
        WRAPPER_EXIT_CODE=1
      else
        WRAPPER_EXIT_CODE=0
      fi
      return 1
      ;;
    done)
      return 0
      ;;
    *)
      log_error "unexpected decision: $LAST_DECISION"
      WRAPPER_EXIT_CODE=1
      return 1
      ;;
  esac
}

main() {
  parse_args "$@"
  validate_config
  check_dependencies
  resolve_project_dir
  initialize_paths
  collect_input_files

  if [[ ${#AGENT_ARGS[@]} -eq 0 ]]; then
    log_error "no arguments provided for codex. See --help for usage."
    exit 1
  fi

  trap cleanup EXIT INT TERM

  log "project_dir=$PROJECT_DIR files=${#INPUT_FILES[@]} include_patterns=${INCLUDE_PATTERNS[*]:-<none>} exclude_patterns=${IGNORE_PATTERNS[*]:-<none>} max_files=$MAX_FILES completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script
  merge_hooks_file

  WRAPPER_EXIT_CODE=0

  for CURRENT_FILE in "${INPUT_FILES[@]}"; do
    if [[ "$MAX_FILES" -gt 0 ]] && [[ "$PROCESSED_COUNT" -ge "$MAX_FILES" ]]; then
      log "maximum files reached: $MAX_FILES"
      break
    fi

    PROCESSED_COUNT=$((PROCESSED_COUNT + 1))
    log "processing file $PROCESSED_COUNT/${#INPUT_FILES[@]}: $CURRENT_FILE"
    expand_template "$CURRENT_FILE"
    run_agent_once "${EXPANDED_ARGS[@]}"
    if ! eval_run_result; then
      return "$WRAPPER_EXIT_CODE"
    fi
  done

  if [[ "$FAILED_RUNS" -gt 0 ]]; then
    return 1
  fi
}

main "$@"
