#!/usr/bin/env bash
#
# codex-timer - Run Codex CLI on a cron schedule
#
# USAGE
#     codex-timer [OPTIONS] [--] [CODEX_ARGS...]
#
# DESCRIPTION
#     Waits for the next minute that matches a 5-field cron expression, then
#     launches Codex CLI. After Codex completes a turn, codex-timer waits for
#     the next matching minute and launches a fresh Codex process.
#
#     Uses Codex's Stop hook mechanism to ensure control returns to the timer
#     after each scheduled run, supporting both interactive and `exec` modes.
#
# OPTIONS
#     --cron EXPR
#         Cron expression in "minute hour day month weekday" format.
#         Supports ranges, lists, steps, month names, weekday names, and
#         aliases such as @hourly, @daily, @weekly, @monthly, and @yearly.
#
#     --max-triggers N
#         Stop after N scheduled Codex runs. Default: 0 (unlimited)
#
#     --completion-promise TEXT
#     --loop-completion-promise TEXT
#         Stop the timer when TEXT appears in Codex's latest assistant message
#
#     --debug
#     --loop-debug
#         Enable codex-timer debug logging
#
#     --help, -h
#         Show this help message
#
#     All other options are passed through to codex.
#
# EXAMPLES
#     codex-timer --cron '0 * * * *' -- exec "summarize repo status"
#     codex-timer --cron '*/15 9-18 * * 1-5' -- exec --full-auto "review work"
#     codex-timer --cron '@daily' --completion-promise "DONE" -- "work"
#
# DEPENDENCIES
#     - bash
#     - codex
#     - jq
#

set -euo pipefail

readonly WRAPPER_NAME="codex-timer"
readonly AGENT_NAME="Codex CLI"
: "${CODEX_TIMER_BIN:=codex}"
readonly AGENT_BIN="$CODEX_TIMER_BIN"

CRON_EXPR=""
MAX_TRIGGERS=0
COMPLETION_PROMISE=""
DEBUG=false
TRIGGER_COUNT=0
AGENT_ARGS=()
PROJECT_DIR=""
CODEX_DIR=""
HOOKS_DIR=""
STATE_FILE=""
HOOKS_FILE=""
HOOKS_FILE_BACKUP=""
HOOK_SCRIPT_PATH=""
DEBUG_FLAG_FILE=""
HOOK_LOG_FILE=""
HOOKS_MODIFIED=false
DATE_BACKEND=""

MINUTE_FIELD=""
HOUR_FIELD=""
DAY_OF_MONTH_FIELD=""
MONTH_FIELD=""
DAY_OF_WEEK_FIELD=""
MINUTE_VALUES=""
HOUR_VALUES=""
DAY_OF_MONTH_VALUES=""
MONTH_VALUES=""
DAY_OF_WEEK_VALUES=""

LAST_EXIT_CODE=0
LAST_DECISION="null"
LAST_HOOK_CALLED="false"
TIMER_EXIT_CODE=0

log() {
  [[ "$DEBUG" == "true" ]] && printf '[%s] %s\n' "$WRAPPER_NAME" "$1" >&2 || true
}

log_error() {
  printf '[%s] ERROR: %s\n' "$WRAPPER_NAME" "$1" >&2
}

show_usage() {
  awk '
    NR >= 2 {
      if ($0 !~ /^#/) { exit }
      sub(/^# ?/, "")
      print
    }
  ' "$0"
}

check_dependencies() {
  command -v "$AGENT_BIN" >/dev/null 2>&1 || {
    log_error "$AGENT_NAME executable not found: $AGENT_BIN"
    exit 1
  }
  command -v jq >/dev/null 2>&1 || {
    log_error "jq is required but not installed."
    exit 1
  }
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cron)
        [[ $# -ge 2 ]] || { log_error "--cron requires a value."; exit 1; }
        CRON_EXPR="$2"
        shift 2
        ;;
      --max-triggers)
        [[ $# -ge 2 ]] || { log_error "--max-triggers requires a value."; exit 1; }
        MAX_TRIGGERS="$2"
        shift 2
        ;;
      --completion-promise|--loop-completion-promise)
        [[ $# -ge 2 ]] || { log_error "$1 requires a value."; exit 1; }
        COMPLETION_PROMISE="$2"
        shift 2
        ;;
      --debug|--loop-debug)
        DEBUG=true
        shift
        ;;
      --help|-h)
        show_usage
        exit 0
        ;;
      --)
        shift
        AGENT_ARGS+=("$@")
        break
        ;;
      *)
        AGENT_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

path_to_absolute() {
  local path="$1"
  case "$path" in
    "~") path="$HOME" ;;
    "~/"*) path="$HOME/${path#"~/"}" ;;
  esac
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    .) printf '%s\n' "$PWD" ;;
    ./*) printf '%s\n' "$PWD/${path#./}" ;;
    *) printf '%s\n' "$PWD/$path" ;;
  esac
}

resolve_project_dir() {
  local candidate="$PWD"
  local i arg
  for ((i = 0; i < ${#AGENT_ARGS[@]}; i++)); do
    arg="${AGENT_ARGS[$i]}"
    case "$arg" in
      -C|--cd)
        if (( i + 1 < ${#AGENT_ARGS[@]} )); then
          candidate="${AGENT_ARGS[$((i + 1))]}"
        fi
        ;;
      --cd=*)
        candidate="${arg#--cd=}"
        ;;
    esac
  done
  candidate=$(path_to_absolute "$candidate")
  PROJECT_DIR=$(cd "$candidate" 2>/dev/null && pwd) || {
    log_error "cannot access codex working directory: $candidate"
    exit 1
  }
}

initialize_paths() {
  CODEX_DIR="${PROJECT_DIR}/.codex"
  HOOKS_DIR="${CODEX_DIR}/hooks"
  STATE_FILE="${CODEX_DIR}/codex-timer.state.json"
  HOOKS_FILE="${CODEX_DIR}/hooks.json"
  HOOKS_FILE_BACKUP="${HOOKS_FILE}.codex-timer-backup"
  HOOK_SCRIPT_PATH="${HOOKS_DIR}/codex-timer-hook.sh"
  DEBUG_FLAG_FILE="${CODEX_DIR}/codex-timer.debug"
  HOOK_LOG_FILE="${CODEX_DIR}/codex-timer-hook.log"
}

init_date_backend() {
  if date -r 0 '+%Y' >/dev/null 2>&1; then
    DATE_BACKEND="bsd"
  elif date -d '@0' '+%Y' >/dev/null 2>&1; then
    DATE_BACKEND="gnu"
  else
    log_error "this system date command is not supported."
    exit 1
  fi
}

format_epoch() {
  local epoch="$1" format="$2"
  case "$DATE_BACKEND" in
    bsd) date -r "$epoch" "$format" ;;
    gnu) date -d "@$epoch" "$format" ;;
    *) log_error "date backend not initialized."; exit 1 ;;
  esac
}

epoch_to_cron_fields() {
  format_epoch "$1" '+%M %H %d %m %w'
}

format_human_time() {
  format_epoch "$1" '+%Y-%m-%d %H:%M:%S %Z'
}

normalize_cron_expr() {
  case "$CRON_EXPR" in
    @yearly|@annually) CRON_EXPR='0 0 1 1 *' ;;
    @monthly) CRON_EXPR='0 0 1 * *' ;;
    @weekly) CRON_EXPR='0 0 * * 0' ;;
    @daily|@midnight) CRON_EXPR='0 0 * * *' ;;
    @hourly) CRON_EXPR='0 * * * *' ;;
  esac
}

normalize_field_names() {
  local value="$1" kind="$2"
  value=$(printf '%s' "$value" | tr '[:lower:]' '[:upper:]')
  case "$kind" in
    month)
      value="${value//JAN/1}"
      value="${value//FEB/2}"
      value="${value//MAR/3}"
      value="${value//APR/4}"
      value="${value//MAY/5}"
      value="${value//JUN/6}"
      value="${value//JUL/7}"
      value="${value//AUG/8}"
      value="${value//SEP/9}"
      value="${value//OCT/10}"
      value="${value//NOV/11}"
      value="${value//DEC/12}"
      ;;
    weekday)
      value="${value//SUN/0}"
      value="${value//MON/1}"
      value="${value//TUE/2}"
      value="${value//WED/3}"
      value="${value//THU/4}"
      value="${value//FRI/5}"
      value="${value//SAT/6}"
      ;;
  esac
  printf '%s\n' "$value"
}

parse_cron_number() {
  local raw="$1" min="$2" max="$3" field_name="$4"
  [[ "$raw" =~ ^[0-9]+$ ]] || { log_error "invalid $field_name field value: $raw"; exit 1; }
  local value=$((10#$raw))
  (( value >= min && value <= max )) || { log_error "$field_name field value out of range: $raw"; exit 1; }
  printf '%s\n' "$value"
}

canonicalize_weekday() {
  local value="$1"
  if [[ "$value" -eq 7 ]]; then
    printf '0\n'
  else
    printf '%s\n' "$value"
  fi
}

build_value_set() {
  local raw_field="$1" parse_min="$2" parse_max="$3" output_min="$4" output_max="$5"
  local kind="$6" field_name="$7" output_var="$8"
  local normalized part base step start end current canonical values=""
  local -a allowed=()

  normalized=$(normalize_field_names "$raw_field" "$kind")
  IFS=',' read -r -a parts <<< "$normalized"
  [[ ${#parts[@]} -gt 0 ]] || { log_error "invalid $field_name field: $raw_field"; exit 1; }

  for part in "${parts[@]}"; do
    [[ -n "$part" ]] || { log_error "invalid $field_name field: $raw_field"; exit 1; }
    base="$part"
    step=1
    if [[ "$part" == */* ]]; then
      [[ "$part" != */*/* ]] || { log_error "invalid $field_name field step: $part"; exit 1; }
      base="${part%/*}"
      step="${part#*/}"
      [[ "$step" =~ ^[0-9]+$ ]] || { log_error "invalid $field_name field step: $part"; exit 1; }
      (( 10#$step > 0 )) || { log_error "$field_name field step must be greater than zero: $part"; exit 1; }
      step=$((10#$step))
    fi

    if [[ "$base" == "*" ]]; then
      start="$parse_min"
      end="$parse_max"
    elif [[ "$base" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      start=$(parse_cron_number "${BASH_REMATCH[1]}" "$parse_min" "$parse_max" "$field_name")
      end=$(parse_cron_number "${BASH_REMATCH[2]}" "$parse_min" "$parse_max" "$field_name")
      (( start <= end )) || { log_error "$field_name field range start exceeds end: $part"; exit 1; }
    else
      start=$(parse_cron_number "$base" "$parse_min" "$parse_max" "$field_name")
      end="$start"
    fi

    for ((current = start; current <= end; current += step)); do
      if [[ "$kind" == "weekday" ]]; then
        canonical=$(canonicalize_weekday "$current")
      else
        canonical="$current"
      fi
      allowed[$canonical]=1
    done
  done

  for ((current = output_min; current <= output_max; current++)); do
    [[ "${allowed[$current]:-0}" == "1" ]] || continue
    [[ -n "$values" ]] && values+=" "
    values+="$current"
  done

  [[ -n "$values" ]] || { log_error "invalid $field_name field: $raw_field"; exit 1; }
  printf -v "$output_var" '%s' "$values"
}

value_in_set() {
  local values="$1" needle="$2"
  [[ " $values " == *" $needle "* ]]
}

cron_matches_epoch() {
  local epoch="$1" minute hour day_of_month month day_of_week
  local dom_match=false dow_match=false
  read -r minute hour day_of_month month day_of_week <<< "$(epoch_to_cron_fields "$epoch")"
  minute=$((10#$minute))
  hour=$((10#$hour))
  day_of_month=$((10#$day_of_month))
  month=$((10#$month))
  day_of_week=$((10#$day_of_week))

  value_in_set "$MINUTE_VALUES" "$minute" || return 1
  value_in_set "$HOUR_VALUES" "$hour" || return 1
  value_in_set "$MONTH_VALUES" "$month" || return 1
  value_in_set "$DAY_OF_MONTH_VALUES" "$day_of_month" && dom_match=true
  value_in_set "$DAY_OF_WEEK_VALUES" "$day_of_week" && dow_match=true

  if [[ "$DAY_OF_MONTH_FIELD" == "*" && "$DAY_OF_WEEK_FIELD" == "*" ]]; then
    return 0
  fi
  if [[ "$DAY_OF_MONTH_FIELD" == "*" ]]; then
    [[ "$dow_match" == "true" ]]
    return
  fi
  if [[ "$DAY_OF_WEEK_FIELD" == "*" ]]; then
    [[ "$dom_match" == "true" ]]
    return
  fi
  [[ "$dom_match" == "true" || "$dow_match" == "true" ]]
}

validate_config() {
  [[ -n "$CRON_EXPR" ]] || { log_error "--cron is required."; exit 1; }
  [[ "$MAX_TRIGGERS" =~ ^[0-9]+$ ]] || { log_error "max-triggers must be a non-negative integer."; exit 1; }

  normalize_cron_expr
  init_date_backend

  local -a fields=()
  read -r -a fields <<< "$CRON_EXPR"
  [[ ${#fields[@]} -eq 5 ]] || { log_error "cron expression must contain exactly 5 fields."; exit 1; }

  MINUTE_FIELD="${fields[0]}"
  HOUR_FIELD="${fields[1]}"
  DAY_OF_MONTH_FIELD="${fields[2]}"
  MONTH_FIELD="${fields[3]}"
  DAY_OF_WEEK_FIELD="${fields[4]}"

  build_value_set "$MINUTE_FIELD" 0 59 0 59 minute minute MINUTE_VALUES
  build_value_set "$HOUR_FIELD" 0 23 0 23 hour hour HOUR_VALUES
  build_value_set "$DAY_OF_MONTH_FIELD" 1 31 1 31 day_of_month day-of-month DAY_OF_MONTH_VALUES
  build_value_set "$MONTH_FIELD" 1 12 1 12 month month MONTH_VALUES
  build_value_set "$DAY_OF_WEEK_FIELD" 0 7 0 6 weekday day-of-week DAY_OF_WEEK_VALUES
}

write_state() {
  local decision="${1:-null}" hook_called="${2:-false}" stop_reason="${3:-}"
  mkdir -p "$CODEX_DIR"
  cat > "$STATE_FILE" << EOF
{
  "active": true,
  "completion_promise": $(printf '%s' "$COMPLETION_PROMISE" | jq -Rs .),
  "decision": $(if [[ "$decision" == "null" ]]; then echo "null"; else printf '"%s"' "$decision"; fi),
  "hook_called": $hook_called,
  "stop_reason": $(printf '%s' "$stop_reason" | jq -Rs .)
}
EOF
}

read_decision() {
  [[ -f "$STATE_FILE" ]] && jq -r '.decision // "null"' "$STATE_FILE" || echo "null"
}

read_hook_called() {
  [[ -f "$STATE_FILE" ]] && jq -r '.hook_called // false' "$STATE_FILE" || echo "false"
}

read_stop_reason() {
  [[ -f "$STATE_FILE" ]] && jq -r '.stop_reason // ""' "$STATE_FILE" || echo ""
}

create_hook_script() {
  mkdir -p "$HOOKS_DIR"
  cat > "$HOOK_SCRIPT_PATH" << 'HOOKEOF'
#!/usr/bin/env bash
set -euo pipefail

CODEX_DIR="$(cd "$(dirname "$0")/.." && pwd)"
STATE_FILE="${CODEX_DIR}/codex-timer.state.json"
DEBUG_FLAG_FILE="${CODEX_DIR}/codex-timer.debug"
HOOK_LOG_FILE="${CODEX_DIR}/codex-timer-hook.log"

debug_log() {
  [[ -f "$DEBUG_FLAG_FILE" ]] || return 0
  mkdir -p "$(dirname "$HOOK_LOG_FILE")"
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$HOOK_LOG_FILE"
}

INPUT=$(cat)

[[ ! -f "$STATE_FILE" ]] && exit 0

STATE=$(cat "$STATE_FILE")
[[ $(echo "$STATE" | jq -r '.active // false') != "true" ]] && exit 0

TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path // empty')
COMPLETION_PROMISE=$(echo "$STATE" | jq -r '.completion_promise // ""')
LAST_ASSISTANT_MESSAGE=$(echo "$INPUT" | jq -r '.last_assistant_message // empty')
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false')
ASSISTANT_TEXT="$LAST_ASSISTANT_MESSAGE"

debug_log "Stop hook started: completion_promise=${COMPLETION_PROMISE:-<none>} stop_hook_active=$STOP_HOOK_ACTIVE transcript_path=${TRANSCRIPT_PATH:-<none>}"

if [[ -z "$ASSISTANT_TEXT" ]] && [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
  ASSISTANT_TEXT=$(jq -r '
    select(.type == "assistant")
    | .message.content[]?
    | select(.type == "text")
    | .text // empty
  ' "$TRANSCRIPT_PATH" 2>/dev/null | tail -n 1 || true)
fi

DECISION="done"
STOP_REASON=""

if [[ -n "$COMPLETION_PROMISE" ]] && [[ -n "$ASSISTANT_TEXT" ]] && grep -qF -- "$COMPLETION_PROMISE" <<< "$ASSISTANT_TEXT"; then
  DECISION="complete"
  STOP_REASON="Completion promise matched."
  debug_log "decision=complete"
else
  debug_log "decision=done"
fi

jq --arg decision "$DECISION" --arg reason "$STOP_REASON" \
  '.decision = $decision | .hook_called = true | .stop_reason = $reason' \
  "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"

if [[ -n "$STOP_REASON" ]]; then
  jq -cn --arg reason "$STOP_REASON" '{"continue": false, "stopReason": $reason}'
else
  jq -cn '{"continue": false}'
fi

debug_log "sending SIGTERM to codex process (PID=$PPID)"
kill -TERM "$PPID" 2>/dev/null || true
exit 0
HOOKEOF

  chmod +x "$HOOK_SCRIPT_PATH"
  if [[ "$DEBUG" == "true" ]]; then
    touch "$DEBUG_FLAG_FILE"
  fi
}

merge_hooks_file() {
  local tmp_file
  mkdir -p "$CODEX_DIR"

  if [[ -f "$HOOKS_FILE" ]]; then
    cp "$HOOKS_FILE" "$HOOKS_FILE_BACKUP"
  fi

  if [[ -f "$HOOKS_FILE" ]]; then
    tmp_file=$(mktemp "${TMPDIR:-/tmp}/${WRAPPER_NAME}.hooks.XXXXXX")
    jq --arg cmd "$HOOK_SCRIPT_PATH" '
      .hooks = (.hooks // {})
      | .hooks.Stop = (
          ((.hooks.Stop // [])
            | map(.hooks = ((.hooks // []) | map(select(.command != $cmd))))
            | map(select((.hooks | length) > 0))
          )
          + [{"hooks":[{"type":"command","command":$cmd,"timeout":30}]}]
        )
    ' "$HOOKS_FILE" > "$tmp_file"
    mv "$tmp_file" "$HOOKS_FILE"
  else
    jq -n --arg cmd "$HOOK_SCRIPT_PATH" '
      {
        hooks: {
          Stop: [
            {
              hooks: [
                {
                  type: "command",
                  command: $cmd,
                  timeout: 30
                }
              ]
            }
          ]
        }
      }
    ' > "$HOOKS_FILE"
  fi

  HOOKS_MODIFIED=true
  log "hook registered in $HOOKS_FILE"
}

restore_hooks_file() {
  [[ "$HOOKS_MODIFIED" == "true" ]] || return 0
  if [[ -f "$HOOKS_FILE_BACKUP" ]]; then
    mv "$HOOKS_FILE_BACKUP" "$HOOKS_FILE"
  else
    rm -f "$HOOKS_FILE"
  fi
  HOOKS_MODIFIED=false
}

cleanup() {
  local exit_code=$?
  rm -f "$HOOK_SCRIPT_PATH"
  rm -f "$DEBUG_FLAG_FILE"
  rm -f "$HOOK_LOG_FILE"
  restore_hooks_file
  rm -f "$STATE_FILE"
  rmdir "$HOOKS_DIR" 2>/dev/null || true
  rmdir "$CODEX_DIR" 2>/dev/null || true
  exit "$exit_code"
}

run_agent_once() {
  local -a args=("$@")
  local -a run_args=(-c "features.codex_hooks=true" "${args[@]}")
  local codex_exit_code decision hook_called stop_reason

  write_state "null" "false"

  set +e
  "$AGENT_BIN" "${run_args[@]}"
  codex_exit_code=$?
  set -e

  decision=$(read_decision)
  hook_called=$(read_hook_called)
  stop_reason=$(read_stop_reason)

  log "$AGENT_BIN exited (code=$codex_exit_code, decision=$decision, hook=$hook_called, reason=${stop_reason:-<none>})"

  LAST_EXIT_CODE=$codex_exit_code
  LAST_DECISION=$decision
  LAST_HOOK_CALLED=$hook_called
}

eval_run_result() {
  if [[ "$LAST_HOOK_CALLED" != "true" ]]; then
    case "$LAST_EXIT_CODE" in
      129|130|137|143)
        log "interrupted by signal"
        TIMER_EXIT_CODE=$LAST_EXIT_CODE
        return 1
        ;;
      *)
        log "hook not called; exiting with codex's status"
        TIMER_EXIT_CODE=$LAST_EXIT_CODE
        return 1
        ;;
    esac
  fi

  case "$LAST_EXIT_CODE" in
    0|129|130|137|143)
      ;;
    *)
      log "non-zero exit code: $LAST_EXIT_CODE, continuing to wait for the next schedule"
      ;;
  esac

  case "$LAST_DECISION" in
    complete)
      log "completion promise matched after trigger $TRIGGER_COUNT"
      TIMER_EXIT_CODE=0
      return 1
      ;;
    done)
      return 0
      ;;
    *)
      log_error "unexpected decision: $LAST_DECISION"
      TIMER_EXIT_CODE=1
      return 1
      ;;
  esac
}

next_minute_boundary_epoch() {
  local now
  now=$(date +%s)
  printf '%s\n' $(( ((now / 60) + 1) * 60 ))
}

current_minute_epoch() {
  local now
  now=$(date +%s)
  printf '%s\n' $(( (now / 60) * 60 ))
}

sleep_until_epoch() {
  local target="$1"
  while true; do
    local now remaining
    now=$(date +%s)
    remaining=$((target - now))
    (( remaining <= 0 )) && return 0
    sleep "$remaining"
  done
}

main() {
  parse_args "$@"
  validate_config
  check_dependencies
  resolve_project_dir
  initialize_paths
  trap cleanup EXIT INT TERM

  log "project_dir=$PROJECT_DIR cron=$CRON_EXPR max_triggers=$MAX_TRIGGERS completion_promise=${COMPLETION_PROMISE:-<none>}"

  create_hook_script
  merge_hooks_file

  TIMER_EXIT_CODE=0

  while true; do
    local target_epoch check_epoch
    target_epoch=$(next_minute_boundary_epoch)
    log "next schedule check at $(format_human_time "$target_epoch")"
    sleep_until_epoch "$target_epoch"

    check_epoch=$(current_minute_epoch)
    if ! cron_matches_epoch "$check_epoch"; then
      log "schedule did not match at $(format_human_time "$check_epoch")"
      continue
    fi

    TRIGGER_COUNT=$((TRIGGER_COUNT + 1))
    log "schedule matched at $(format_human_time "$check_epoch"), running $AGENT_BIN (trigger $TRIGGER_COUNT)"

    run_agent_once "${AGENT_ARGS[@]}"
    if ! eval_run_result; then
      return "$TIMER_EXIT_CODE"
    fi

    if [[ "$MAX_TRIGGERS" -gt 0 ]] && [[ "$TRIGGER_COUNT" -ge "$MAX_TRIGGERS" ]]; then
      log "maximum triggers reached: $TRIGGER_COUNT"
      return 0
    fi

    log "trigger $TRIGGER_COUNT complete, waiting for next schedule"
  done
}

main "$@"
